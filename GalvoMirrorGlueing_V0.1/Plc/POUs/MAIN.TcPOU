    <Action Name="CheckCompatibility" Id="{7544605d-af71-4779-99e5-01b70dde7914}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[
IF stModuleHmi.bProductionStart1To5 AND stModuleHmi.bProductionStart6To10 THEN
	IF stAssemblyData.Station1To5.rGalvoThickness = stAssemblyData.Station5To10.rGalvoThickness THEN
		bCheckPassed := TRUE;
	ELSE
		bCheckPassed := FALSE;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="ErrAck" Id="{1bc8e65e-28d7-4b7c-9dec-ee74371c16a9}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD ErrAck : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bSafetyError AND NOT bErrorAck OR SafetyAckOffTmr.Q THEN
	SafetyAckOffTmr.IN := FALSE;
	bErrorAck := TRUE;
	ErrorAckOffTmr.IN := TRUE;
ELSIF NOT bSafetyError THEN
	SafetyAckOffTmr.IN := FALSE;
END_IF

IF bErrorAck AND ErrorAckOffTmr.Q THEN
	ErrorAckOffTmr.IN := FALSE;
	bErrorAck := FALSE;
	SafetyAckOffTmr.IN := TRUE;
END_IF
SafetyAckOffTmr(PT := T#2S);
ErrorAckOffTmr(PT := T#0.5S);]]></ST>
      </Implementation>
    </Method>
    <Action Name="ErrorList" Id="{8b6958f7-868f-4196-a365-1b60771273a1}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[CASE iRobotError OF
0:	  sErrorText := 'NO_ERROR';
1000: sErrorText := 'COMMAND_BUFFER_IS_FULL';
1001: sErrorText := 'UNKNOWN_COMMAND';
1002: sErrorText := 'SYNTAX_ERROR';
1003: sErrorText := 'ARGUMENT_ERROR';
1005: sErrorText := 'THE_ROBOT_IS_NOT_ACTIVATED';
1006: sErrorText := 'THE_ROBOT_IS_NOT_HOMED';
1007: sErrorText := 'JOINT_OVER_LIMIT';
1010: sErrorText := 'LINEAR_MOVE_BLOCKED_BY_ROTATION';
1011: sErrorText := 'THE_ROBOT_IS_IN_ERROR';
1012: sErrorText := 'SINGULARITY_DETECTED';
1013: sErrorText := 'ACTIVATION_FAILED';
1014: sErrorText := 'HOMING_FAILED';
1016: sErrorText := 'POSE_OUT_OF_REACH';
1022: sErrorText := 'PROGRAM_SAVING_FAILED_1';
1023: sErrorText := 'IGNORING_COMMAND_FOR_OFFLINE_MODE';
1024: sErrorText := 'MASTERING_NEEDED';
1025: sErrorText := 'RESET_ERROR_NOT_POSSIBLE';
1026: sErrorText := 'DeactivatedIVATION_NEEDED';
1027: sErrorText := 'CHANGE_SIMULATION_MODE_FAILED';
1030: sErrorText := 'ALREADY_SAVING';
1031: sErrorText := 'PROGRAM_SAVING_ABORTED';
1033: sErrorText := 'START_CONF_MISMATCH';
1038: sErrorText := 'ERR_NO_GRIPPER_CONNECTED';
1040: sErrorText := 'COMMAND_FAILED';
1041: sErrorText := 'NO_VBOX';
1042: sErrorText := 'EXT_TOOL_SIM_MUST_Deactivated';
1043: sErrorText := 'IO_BANK_NOT_PRESENT';
1044: sErrorText := 'VACUUM_MODULE_NOT_PRESENT';
3005: sErrorText := 'MOTION_ERROR';
3006: sErrorText := 'DRIVE_ERROR';
3009: sErrorText := 'INIT_FAILED';
3014: sErrorText := 'ERROR_SAVING';
3020: sErrorText := 'INVALID_OFFLINE_PROGRAM';
3025: sErrorText := 'GRIPPER_ERROR';
3026: sErrorText := 'MAINTENANCE_CHECK_DISCOVERY';
3029: sErrorText := 'EXCESSIVE_TORQUE';
3037: sErrorText := 'PNEUMATIC_ERROR';
3039: sErrorText := 'EXT_TOOL_NEED_UPDATE';
3041: sErrorText := 'IMMINENT_COLLISION';
3043: sErrorText := 'IO_PORT_PACKET_LOST';
3044: sErrorText := 'IO_PORT_COMM_ERROR';
3045: sErrorText := 'IMMINENT_COLLISION_DETECTED';
3046: sErrorText := 'POWERSUPPLY_ERROR';
3047: sErrorText := 'SAFE_MODE_BOOT';
3049: sErrorText := 'AT_WORKZONE_LIMIT';
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Action Name="ForceHoldersRelease" Id="{915dfa82-4cb7-4e16-8e13-4a7d6c7cf507}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[
CASE iCheckOperationality OF
	0: iCheckOperationality := 1;
	1:	stStation.fbSts1.bReleaseHolders := TRUE;
		iCheckOperationality := 2;
	2: stStation.fbSts2.bReleaseHolders := TRUE;
		iCheckOperationality := 3; 
	3: stStation.fbSts3.bReleaseHolders := TRUE;
		iCheckOperationality := 4;
	4: stStation.fbSts4.bReleaseHolders := TRUE;
		iCheckOperationality := 5;
	5: stStation.fbSts5.bReleaseHolders := TRUE;
		iCheckOperationality := 6;
	6: stStation.fbSts6.bReleaseHolders := TRUE;
		iCheckOperationality := 7;
	7: stStation.fbSts7.bReleaseHolders := TRUE;
		iCheckOperationality := 8;
	8: stStation.fbSts8.bReleaseHolders := TRUE;
		iCheckOperationality := 9;
	9: stStation.fbSts9.bReleaseHolders := TRUE;
		iCheckOperationality := 10;
	10:stStation.fbSts10.bReleaseHolders := TRUE;
		iCheckOperationality := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
