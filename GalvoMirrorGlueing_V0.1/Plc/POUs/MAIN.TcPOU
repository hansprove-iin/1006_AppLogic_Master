    <Method Name="HatchLight" Id="{bcf5b322-a933-4383-bc03-9d4019c65204}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD HatchLight : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//stPlcCom.stPlcComOut.bRingLightInfeed := TRUE;
IF NOT stPlcCom.stPlcComIn.bSafetyOk AND NOT stModuleHmi.bModuleProductionStart THEN
	stPlcCom.stPlcComOut.bRingLightInfeed := TRUE;
	stPlcCom.stPlcComOut.bRingLightPass := TRUE;
	stPlcCom.stPlcComOut.bRingLightReject := TRUE;
	bRinglightsSet	:= TRUE;
ELSIF bRinglightsSet THEN
	stPlcCom.stPlcComOut.bRingLightInfeed := FALSE;
	stPlcCom.stPlcComOut.bRingLightPass := FALSE;
	stPlcCom.stPlcComOut.bRingLightReject := FALSE;
	bRinglightsSet := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="HatchLocks" Id="{2a5ece7f-27aa-49d2-b2ae-746e38a96812}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD HatchLocks
VAR
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bUnlockGlueDoor THEN
	stPlcCom.stPlcComOut.bGlueDoorLock := FALSE;
ELSIF bLockAll THEN
	stPlcCom.stPlcComOut.bGlueDoorLock := TRUE;
	stPlcCom.stPlcComOut.bHatchesLock := TRUE;
	LockTmr.IN := TRUE;
ELSE
	stPlcCom.stPlcComOut.bGlueDoorLock := FALSE;
	stPlcCom.stPlcComOut.bHatchesLock := FALSE;
END_IF


IF NOT stPlcCom.stPlcComIn.bEstopOk OR NOT stPlcCom.stPlcComIn.bSafetyOk OR fbMeca500.bRobotConfDone AND NOT stModuleHmi.bModuleProductionStart AND stModuleHmi.bModuleStartupDone OR NOT stModuleHmi.bModulePlayPause AND fbMeca500.bRobotConfDone AND fbMeca500.bRobotHomed AND stModuleHmi.bModuleStartupDone OR stModuleHmi.bOpenAllLocks THEN
	bLockAll := FALSE;
	bUnlockGlueDoor := FALSE;
ELSIF stPlcCom.stPlcComIn.bSafetyOk AND NOT fbMeca500.bRobotConfDone OR fbMeca500.bRobotConfDone AND stModuleHmi.bModuleProductionStart THEN
	IF NOT stModuleHmi.bModuleFault THEN
		bLockAll := TRUE;
		bUnlockGlueDoor := FALSE;
	END_IF
END_IF



IF (*stPlcCom.stPlcComIn.bGlueDoorLowerLockClosed AND *)stPlcCom.stPlcComIn.bGlueDoorUpperLockClosed AND stPlcCom.stPlcComIn.bInfeedLockClosed 
	AND stPlcCom.stPlcComIn.bMainDoorLockClosed AND stPlcCom.stPlcComIn.bPassLockClosed AND stPlcCom.stPlcComIn.bRejectLockClosed AND bLockAll THEN
	bLocksEngaged := TRUE;
	LockTmr.IN := FALSE;
ELSE
	
	IF bLockAll AND LockTmr.Q AND NOT bLocksEngaged THEN
		bLockAll := FALSE;
		bLocksEngaged := FALSE;
		LockTmr.IN := FALSE;
		bUnlockGlueDoor := FALSE;
		fbEventLogger.sErrorCode:='401';
		fbEventLogger.bRaiseAlarm[15] :=TRUE;
	END_IF
END_IF
LockTmr(PT := T#3S);]]></ST>
      </Implementation>
    </Method>
    <Action Name="LaserPointers" Id="{0223ac47-5447-43d8-8b90-301b560aec0e}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[IF NOT stModuleHmi.bModuleStartupDone THEN
	stPlcCom.stPlcComOut.bLaserPointers1To5 := TRUE;
	stPlcCom.stPlcComOut.bLaserPointers5To10 := TRUE;
ELSIF stStation.fbSts1.bTrigAngCam OR stStation.fbSts2.bTrigAngCam OR stStation.fbSts1.bTrigPosCamLaserTest OR stStation.fbSts2.bTrigPosCamLaserTest  OR stStation.fbSts3.bTrigAngCam OR stStation.fbSts4.bTrigAngCam OR stStation.fbSts3.bTrigPosCamLaserTest OR stStation.fbSts4.bTrigPosCamLaserTest OR stStation.fbSts5.bTrigAngCam OR stStation.fbSts5.bTrigPosCamLaserTest THEN
	stPlcCom.stPlcComOut.bLaserPointers1To5 := TRUE;
ELSE
	stPlcCom.stPlcComOut.bLaserPointers1To5 := FALSE;
	stPlcCom.stPlcComOut.bLaserPointers5To10 := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="LightTower" Id="{a6f1f7c8-f88b-42d5-952f-9d25397e5fed}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[IF NOT stPlcCom.stPlcComIn.bSafetyOk OR NOT stPlcCom.stPlcComIn.bEstopOk OR stModuleHmi.bProductionStartFailure OR stModuleHmi.bModuleFault THEN
	fbLightTower.bRedEnable := TRUE;
	fbLightTower.bBlinkEnable := TRUE;
ELSIF stModuleHmi.bModuleProductionStart THEN
	fbLightTower.bRedEnable := FALSE;
	fbLightTower.bBlinkEnable := FALSE;
	fbLightTower.bToneEnable := TRUE;
ELSIF stModuleHmi.bModuleProductionStart THEN
	fbLightTower.bRedEnable := FALSE;
	fbLightTower.bBlinkEnable := FALSE;
	fbLightTower.bToneEnable := FALSE;
	fbLightTower.bYellowEnable := FALSE;
	fbLightTower.bGreenEnable := TRUE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="OutfeedLight" Id="{498a9713-ad82-4960-8fb3-d5145325ef35}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD OutfeedLight
VAR_INPUT
	IN : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IN THEN
	stPlcCom.stPlcComOut.bRingLightInfeed := TRUE;
	stPlcCom.stPlcComOut.bRingLightPass := TRUE;
	stPlcCom.stPlcComOut.bRingLightReject := TRUE;
ELSE
	stPlcCom.stPlcComOut.bRingLightInfeed := FALSE;
	stPlcCom.stPlcComOut.bRingLightPass := FALSE;
	stPlcCom.stPlcComOut.bRingLightReject := FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="PowerBtn" Id="{b06761a9-9b91-4d15-9e4b-f44db78fef31}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD PowerBtn : BOOL
VAR_INPUT
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[RelayOnTmr(IN :=  bSetRelay, PT := T#1S, Q => stPlcCom.stPlcComOut.bPowerOff);
bSetRelay := FALSE;
IF NOT stModuleHmi.bModuleProductionStart THEN
		IF stModuleHmi.bModuleStartupDone AND fbMeca500.bRobotHomed OR NOT stModuleHmi.bModuleStartup OR stModuleHmi.bModuleFault THEN
			IF stModuleHmi.bPowerOff AND NOT bSet THEN
				bSetRelay := TRUE;
				bSet := TRUE;
			END_IF
		END_IF 
END_IF
IF NOT stPlcCom.stPlcComIn.bAcOk THEN
	stModuleHmi.bAcOk := TRUE;
ELSE
	stModuleHmi.bAcOk := FALSE;
	fbEventLogger.sErrorCode:='403';
	fbEventLogger.bRaiseAlarm[18]:= TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="RejectLight" Id="{da123b9c-804f-45f4-afe0-a8845545be2c}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD RejectLight
VAR_INPUT
	IN : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IN THEN
	stPlcCom.stPlcComOut.bRingLightPass := TRUE;
	stPlcCom.stPlcComOut.bRingLightReject := TRUE;
ELSE
	stPlcCom.stPlcComOut.bRingLightReject := FALSE;
	stPlcCom.stPlcComOut.bRingLightPass := FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="ResetLight" Id="{548d9907-8d96-40e9-ab52-3c12a18bd464}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD ResetLight : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[ResetButtonTmr1();
ResetButtonTmr2();
IF NOT stPlcCom.stPlcComIn.bEstopOk OR NOT stPlcCom.stPlcComIn.bSafetyOk THEN
	IF ResetButtonTmr2.Q OR bSetOnce THEN
		bSetOnce := FALSE;
		stPlcCom.stPlcComOut.bResetButtonLight := TRUE;
		ResetButtonTmr2.IN := FALSE;
		ResetButtonTmr1.IN := TRUE;
	END_IF
	IF ResetButtonTmr1.Q THEN
		stPlcCom.stPlcComOut.bResetButtonLight := FALSE;
		ResetButtonTmr2.IN := TRUE;
		ResetButtonTmr1.IN := FALSE;
	END_IF
ELSE
	bSetOnce := TRUE;
	stPlcCom.stPlcComOut.bResetButtonLight := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Action Name="ResetStations" Id="{948baeed-5bde-4700-a8d6-b031bef751be}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[
CASE iCheckOperationality OF
	0: IF stModuleHmi.bProductionStart1To5 THEN
			iCheckOperationality := 1;
		ELSIF stModuleHmi.bProductionStart6To10 THEN
			iCheckOperationality := 6;
		END_IF
	1:	IF stStation.fbSts1.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation1 := TRUE;
		END_IF
		iCheckOperationality := 2;
	2: IF stStation.fbSts2.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation2 := TRUE;
		END_IF
		iCheckOperationality := 3; 
	3: IF stStation.fbSts3.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation3 := TRUE;
		END_IF
		iCheckOperationality := 4;
	4: IF stStation.fbSts4.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation4 := TRUE;
		END_IF
		iCheckOperationality := 5;
	5: IF stStation.fbSts5.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation5 := TRUE;
		END_IF
		iCheckOperationality := 6;
	6: IF stStation.fbSts6.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation6 := TRUE;
		END_IF
		iCheckOperationality := 7;
	7: IF stStation.fbSts7.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation7 := TRUE;
		END_IF
		iCheckOperationality := 8;
	8: IF stStation.fbSts8.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation8 := TRUE;
		END_IF
		iCheckOperationality := 9;
	9: IF stStation.fbSts9.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation9 := TRUE;
		END_IF
		iCheckOperationality := 10;
	10: IF stStation.fbSts10.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation10 := TRUE;
		END_IF
		iCheckOperationality := 0;
END_CASE]]></ST>
      </Implementation>
    </Action>
    <Method Name="ResetStns" Id="{6e0b6be4-a31f-4d67-ad07-ced5b73a1599}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD ResetStns
VAR_INPUT
	All : BOOL;
	Stns1To5 : BOOL;
	Stns6To10 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
CASE iCheckOperationality OF
	0: IF All OR Stns1To5 THEN
			iCheckOperationality := 1;
		ELSIF Stns6To10 THEN
			iCheckOperationality := 6;
		END_IF
	1:	IF stStation.fbSts1.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation1 := TRUE;
		END_IF
		iCheckOperationality := 2;
	2: IF stStation.fbSts2.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation2 := TRUE;
		END_IF
		iCheckOperationality := 3; 
	3: IF stStation.fbSts3.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation3 := TRUE;
		END_IF
		iCheckOperationality := 4;
	4: IF stStation.fbSts4.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation4 := TRUE;
		END_IF
		iCheckOperationality := 5;
	5: IF stStation.fbSts5.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation5 := TRUE;
		END_IF
		IF All THEN
			iCheckOperationality := 6;
		END_IF
	6: IF stStation.fbSts6.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation6 := TRUE;
		END_IF
		iCheckOperationality := 7;
	7: IF stStation.fbSts7.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation7 := TRUE;
		END_IF
		iCheckOperationality := 8;
	8: IF stStation.fbSts8.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation8 := TRUE;
		END_IF
		iCheckOperationality := 9;
	9: IF stStation.fbSts9.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation9 := TRUE;
		END_IF
		iCheckOperationality := 10;
	10: IF stStation.fbSts10.bDisabledByCycleDone THEN
			stModuleHmi.Stations.bActivateStation10 := TRUE;
		END_IF
		iCheckOperationality := 0;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="StartupTrig" Id="{445b4bde-c491-40a5-90e3-4502d2a9f5e0}" FolderPath="Mthd\">
      <Declaration><![CDATA[METHOD StartupTrig
VAR_INPUT
END_VAR
VAR
	bInitialDone : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF fbMeca500.bRobotConfDone AND stStation.fbSts1.bCheckDone AND stStation.fbSts2.bCheckDone AND stStation.fbSts3.bCheckDone AND 
stStation.fbSts4.bCheckDone AND stStation.fbSts5.bCheckDone AND stStation.fbSts6.bCheckDone AND stStation.fbSts7.bCheckDone AND stStation.fbSts8.bCheckDone AND 
stStation.fbSts9.bCheckDone AND stStation.fbSts10.bCheckDone THEN
	stModuleHmi.bModuleStartupDone := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>