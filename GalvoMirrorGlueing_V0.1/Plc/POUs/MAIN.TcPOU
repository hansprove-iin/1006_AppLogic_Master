<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="MAIN" Id="{45c4786d-4d54-4bbe-9427-a04501eddae5}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR RETAIN
	rModuleOperaingSpeed		: REAL := 20;
END_VAR
VAR
	start:FB_CycleStart();	

	RelayOnTmr	: TOF;
	bSetRelay : BOOL;

	fbMeca500	: FB_MecaStateMachine;
	stModuleHmi : ST_ModuleHmi;
	stPlcCom	: ST_Module_PlcCom;
	stStation	: ST_Stations;
	fbLightTower : FB_ASMT60Functions;
	fbEventLogger	:FB_EventLogger;
	
	stCouplerData : ST_CouplerImagingData;
	stAssemblyData	: ST_Recipes;
	fbDataExchange		: FB_RecipeDataExchange;
	StAngleData : ST_AngleData; // RECEIVED ANGLE DATA FROM CPU 1
	fbGlueState	: FB_GlueState;


	fbDataExchangeRead	:FB_DataExchangeRead;
	bGroupRunStop AT %Q* : BOOL := TRUE;
	bSafetyError	 AT %I* : BOOL ;
	bErrorAck	AT %Q* : BOOL;
	SafetyAckOffTmr : TON;
	ErrorAckOffTmr	: TON;
	ResetButtonTmr1	: TON := (
		PT := T#1S);
	ResetButtonTmr2	: TON := (
		PT := T#0.5S);
	bSetOnce : BOOL := TRUE;
	bRinglightsSet	: BOOL;
	bAllowPowerOff	: BOOL;
	bLocksEngaged : BOOL;
	iProductionMainStep : INT;
	bAllowStationPrductionStart1To5 : BOOL;
	bAllowStationPrductionStart6To10 : BOOL;
	bLockAll		: BOOL;
	bUnlockGlueDoor : BOOL;
	LockTmr			: TON;
	sErrorText	: STRING;
	iRobotError	: INT;
	iCheckOperationality : INT;	
	iCheckStep	: INT;	
	bPlacingDone : BOOL;
	bAssemblyDone : BOOL;
	bCheckPassed : BOOL;
	iStepPosSave	: INT;
	bSet : BOOL;
	bNeedleSucceeded : BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[start();


P_Heaters();

fbMeca500(stModuleHmi := stModuleHmi, stStations := stStation, stPlcCom := stPlcCom, stAssemblyData := stAssemblyData, bLocksEngaged := bLocksEngaged, stCouplerData := stCouplerData, rOperatingSpeed := rModuleOperaingSpeed, bNeedleSucceeded := bNeedleSucceeded);
fbDataExchange(sendRecipeData := stAssemblyData, stModuleHmi := stModuleHmi);
fbDataExchangeRead(stModuleHmi := stModuleHmi, stLaserPositionData => StAngleData);
ErrAck();
ResetLight();
HatchLight();
HatchLocks();
PowerBtn();
fbLightTower();
StartupTrig();
LaserPointers();
fbEventLogger(stModuleHmi:=stModuleHmi);
fbGlueState(stModuleHmi := stModuleHmi, stPlcCom := stPlcCom, bDetectionSucceeded := bNeedleSucceeded);


CASE iProductionMainStep OF
	0: IF stModuleHmi.bStartDetection THEN // LISÄÄ ROBOTIN ANTURIN TESTI
			fbMeca500.bExecuteNeedleTest := TRUE;
			stModuleHmi.bStartDetection := FALSE;
		END_IF
		
		IF stModuleHmi.bDispensingStageDone THEN
			iProductionMainStep := 1;
		ELSIF fbMeca500.bNeedleFailed THEN
			fbEventLogger.sErrorCode:='211';
			fbEventLogger.bRaiseAlarm[17]:= TRUE;
			stModuleHmi.bModuleProductionStart := FALSE;
			stModuleHmi.bProductionStart1To5 := FALSE;
			stModuleHmi.bProductionStart6To10 := FALSE;
			stModuleHmi.bProductionStageCompleted := FALSE;
			stModuleHmi.bProductionStartFailure := TRUE;
			iProductionMainStep := 0;
		END_IF

	1: IF stModuleHmi.bModuleProductionStart AND stPlcCom.stPlcComIn.bSafetyOk AND stPlcCom.stPlcComIn.bEstopOk AND stModuleHmi.bModuleStartupDone AND NOT stModuleHmi.bModuleFault THEN
			bLockAll := TRUE;
			stModuleHmi.bModulePlayPause := TRUE;
			stModuleHmi.bProductionStartFailure := FALSE;
			bUnlockGlueDoor := FALSE;
			ForceHoldersRelease();
			IF bLocksEngaged THEN
				iProductionMainStep := 2;
			ELSE
				iProductionMainStep := 30;
			END_IF
		END_IF 
	2: Trig.bOutfeedCam := TRUE;
		OutfeedLight(IN := TRUE);
		IF MAIN_VISION.fbOutfeedCam.bImagingDone THEN
			iProductionMainStep := 3;
			Trig.bOutfeedCam := FALSE;
			OutfeedLight(IN := FALSE);
		ELSIF MAIN_VISION.fbOutfeedCam.bError THEN
			iProductionMainStep := 30;
		END_IF
	3: IF NOT MAIN_VISION.fbOutfeedCam.bPalletRow1NotClear AND NOT MAIN_VISION.fbOutfeedCam.bPalletRow1NotClear THEN
			iProductionMainStep := 4;
			 Trig.bRejectCam := TRUE;
		ELSE
			iProductionMainStep := 30;
		END_IF
	4:	Trig.bRejectCam := TRUE;
		RejectLight(IN := TRUE);
		IF MAIN_VISION.fbRejectCam.bImagingDone THEN
			RejectLight(IN := FALSE);
			iProductionMainStep := 5;
			Trig.bRejectCam := FALSE;
		ELSIF MAIN_VISION.fbRejectCam.bError THEN
			iProductionMainStep := 30;
		END_IF
	5: IF NOT MAIN_VISION.fbRejectCam.bPalletRow1NotClear AND NOT MAIN_VISION.fbRejectCam.bPalletRow1NotClear THEN
			iProductionMainStep := 6;
		ELSE
			iProductionMainStep := 30;
		END_IF
	6: fbMeca500.bExecuteNeedleReTest := TRUE;
		iProductionMainStep := 7;
	7: ResetStns(All := TRUE, Stns1To5 := FALSE, Stns6To10 := FALSE);
		iProductionMainStep := 8;
		
	8: IF fbMeca500.bNeedleRecheckSucceeded (*AND MAIN_VISION.stPalletPosData.bMirrorPalletImagingSucceeded*)  THEN
			fbMeca500.bAllowStart := TRUE;
			IF stModuleHmi.bProductionStart1To5 AND stModuleHmi.bProductionStart6To10 THEN
				bAllowStationPrductionStart1To5 := TRUE;
				bAllowStationPrductionStart6To10 := TRUE;
				fbMeca500.bNewPlacingActive := TRUE;
				iProductionMainStep := 10;
			ELSIF stModuleHmi.bProductionStart1To5 THEN
				bAllowStationPrductionStart1To5 := TRUE;
				bAllowStationPrductionStart6To10 := FALSE; 
				fbMeca500.bNewPlacingActive := TRUE;
				iProductionMainStep := 20;
			END_IF
		ELSIF fbMeca500.bNeedleFailed THEN
			fbEventLogger.sErrorCode:='211';
			fbEventLogger.bRaiseAlarm[17]:= TRUE;
			stModuleHmi.bModuleProductionStart := FALSE;
			fbMeca500.bExecuteNeedleReTest := FALSE;
			stModuleHmi.bProductionStart1To5 := FALSE;
			stModuleHmi.bProductionStart6To10 := FALSE;
			stModuleHmi.bProductionStageCompleted := FALSE;
			stModuleHmi.bProductionStartFailure := TRUE;
			iProductionMainStep := 0;
		END_IF
		
	10: CheckAllPlacingState();
		IF bPlacingDone THEN
			stModuleHmi.bProductionStageCompleted := TRUE; // ALLOWS PAUSE BUTTON PRESS TO OPEN GLUING DOOR
			bPlacingDone := FALSE;
			fbMeca500.bNewPlacingActive := FALSE;
			iCheckStep := 0;
			iProductionMainStep := 11;
		END_IF
		
	11: IF fbMeca500.bDismountingActive THEN
			stModuleHmi.bProductionStageCompleted := FALSE;
		END_IF
		CheckAllAssemblyState();
		IF bAssemblyDone THEN
			bAssemblyDone := FALSE;
			stModuleHmi.bProductionStart1To5 := FALSE;
			stModuleHmi.bProductionStart6To10 := FALSE;
			bAllowStationPrductionStart1To5 := FALSE; 
			bAllowStationPrductionStart6To10 := FALSE; 
			stModuleHmi.bModuleProductionStart := FALSE;
			stModuleHmi.bProductionStageCompleted := FALSE;
			iProductionMainStep := 0;
			iCheckStep := 0;
		END_IF
		
	20: Check1To5PlacingState();
		IF bPlacingDone THEN
			stModuleHmi.bProductionStageCompleted := TRUE; // ALLOWS PAUSE BUTTON PRESS TO OPEN GLUING DOOR
			bPlacingDone := FALSE;
			iCheckStep := 0;
			iProductionMainStep := 21;
		END_IF
		
	21: IF fbMeca500.bDismountingActive THEN
			stModuleHmi.bProductionStageCompleted := FALSE;
		ELSIF stModuleHmi.bProductionStart6To10 THEN
			iStepPosSave := 22;
			iProductionMainStep := 60;
		END_IF
		Check1To5AssemblyState();
		IF bAssemblyDone THEN
			bAssemblyDone := FALSE;
			stModuleHmi.bProductionStart1To5 := FALSE;
			stModuleHmi.bProductionStart6To10 := FALSE;
			bAllowStationPrductionStart1To5 := FALSE; 
			bAllowStationPrductionStart6To10 := FALSE; 
			stModuleHmi.bModuleProductionStart := FALSE;
			stModuleHmi.bProductionStageCompleted := FALSE;
			iProductionMainStep := 0;
			iCheckStep := 0;
		END_IF
	22:	stModuleHmi.bProductionStageCompleted := FALSE;
		bAllowStationPrductionStart6To10 := TRUE;
		fbMeca500.bNewPlacingActive := TRUE;
		iProductionMainStep := 23;
		
	23: Check6To10PlacingState();
		IF bPlacingDone THEN
			fbMeca500.bNewPlacingActive := FALSE;
			stModuleHmi.bProductionStageCompleted := TRUE; // ALLOWS PAUSE BUTTON PRESS TO OPEN GLUING DOOR
			bPlacingDone := FALSE;
			iCheckStep := 0;
			iProductionMainStep := 24;
		END_IF
		
	24: Check1To5AssemblyState();
		IF bAssemblyDone THEN
			bAssemblyDone := FALSE;
			iCheckStep := 0;
			ResetStations();
			bAllowStationPrductionStart1To5 := FALSE; 
			stModuleHmi.bProductionStart1To5 := FALSE;
			iProductionMainStep := 25;
		END_IF
		
	25: IF fbMeca500.bDismountingActive THEN
			stModuleHmi.bProductionStageCompleted := FALSE;
		ELSIF stModuleHmi.bProductionStart1To5 THEN
			iStepPosSave := 26;
			iProductionMainStep := 50;
		END_IF
		Check6To10AssemblyState();
		IF bAssemblyDone THEN
			bAssemblyDone := FALSE;
			stModuleHmi.bProductionStart1To5 := FALSE;
			bAllowStationPrductionStart1To5 := FALSE; 
			bAllowStationPrductionStart6To10 := FALSE; 
			stModuleHmi.bModuleProductionStart := FALSE;
			stModuleHmi.bProductionStart6To10 := FALSE;
			ResetStations();
			stModuleHmi.bProductionStageCompleted := FALSE;
			iProductionMainStep := 0;
			iCheckStep := 0;
		END_IF
	26: fbMeca500.bNewPlacingActive := TRUE;
		bAllowStationPrductionStart1To5 := TRUE; 
		stModuleHmi.bProductionStageCompleted := FALSE;
		iProductionMainStep := 27;
		
	27: Check1To5PlacingState();
		IF bPlacingDone THEN
			fbMeca500.bNewPlacingActive := FALSE;
			stModuleHmi.bProductionStageCompleted := TRUE; // ALLOWS PAUSE BUTTON PRESS TO OPEN GLUING DOOR
			bPlacingDone := FALSE;
			iCheckStep := 0;
			iProductionMainStep := 28;
		END_IF
		
	28: Check6To10AssemblyState();
		IF bAssemblyDone THEN
			bAssemblyDone := FALSE;
			iCheckStep := 0;
			ResetStations();
			bAllowStationPrductionStart6To10 := FALSE; 
			stModuleHmi.bProductionStart6To10 := FALSE;
			iProductionMainStep := 21;
		END_IF
		
	30: bAssemblyDone := FALSE;
		OutfeedLight(IN := FALSE);
		RejectLight(IN := FALSE); 
		stModuleHmi.bProductionStartFailure := TRUE;
		fbMeca500.bExecuteNeedleTest := FALSE;
		stModuleHmi.bProductionStart1To5 := FALSE;
		stModuleHmi.bProductionStart6To10 := FALSE;
		bAllowStationPrductionStart1To5 := FALSE; 
		bAllowStationPrductionStart6To10 := FALSE; 
		stModuleHmi.bModuleProductionStart := FALSE;
		stModuleHmi.bProductionStageCompleted := FALSE;
		stModuleHmi.bModuleProductionStop := FALSE;
		iProductionMainStep := 0;
		iCheckStep := 0;
		
	50: Trig.bOutfeedCam := TRUE;				// Check for pallet positions 1 to 5
		OutfeedLight(IN := TRUE);
		ResetStns(All := FALSE, Stns1To5 := FALSE, Stns6To10 := TRUE);
		IF MAIN_VISION.fbOutfeedCam.bImagingDone THEN
			OutfeedLight(IN := FALSE);
			iProductionMainStep := 51;
			Trig.bOutfeedCam := FALSE;
		ELSIF MAIN_VISION.fbOutfeedCam.bError THEN
			iProductionMainStep := 58;
		END_IF
		
	51: IF NOT MAIN_VISION.fbOutfeedCam.bPalletRow1NotClear THEN // LISÄÄ 		
			Trig.bRejectCam := TRUE;	
			RejectLight(IN := TRUE);
			iProductionMainStep := 52;
		ELSE
			iProductionMainStep := 58;
		END_IF
	52:IF MAIN_VISION.fbRejectCam.bImagingDone THEN
			iProductionMainStep := 53;
			RejectLight(IN := FALSE);
			Trig.bRejectCam := FALSE;
		ELSIF MAIN_VISION.fbRejectCam.bError THEN
			iProductionMainStep := 58;
		END_IF
	53: IF NOT MAIN_VISION.fbRejectCam.bPalletRow1NotClear THEN // LISÄÄ 		
			fbMeca500.bExecuteNeedleTest := TRUE;	
			iProductionMainStep := 54;
		ELSE
			iProductionMainStep := 58;
		END_IF
	
	54: IF bNeedleSucceeded (*AND MAIN_VISION.stPalletPosData.bMirrorPalletImagingSucceeded *)THEN
			iProductionMainStep := iStepPosSave;
		ELSIF fbMeca500.bNeedleFailed THEN
			iProductionMainStep := 58;
		END_IF
		
	58: iProductionMainStep := iStepPosSave-1;
		bAllowStationPrductionStart1To5 := FALSE; 
		OutfeedLight(IN := FALSE);
		RejectLight(IN := FALSE);
		stModuleHmi.bProductionStart1To5 := FALSE;
		Err.Err; //404
		
	60: Trig.bOutfeedCam := TRUE;				// Check for pallet positions 6 to 10
		ResetStns(All := FALSE, Stns1To5 := FALSE, Stns6To10 := TRUE);
		OutfeedLight(IN := TRUE);
		IF MAIN_VISION.fbOutfeedCam.bImagingDone THEN
			OutfeedLight(IN := FALSE);
			iProductionMainStep := 61;
			Trig.bOutfeedCam := FALSE;
		ELSIF MAIN_VISION.fbOutfeedCam.bError THEN
			iProductionMainStep := 68;
		END_IF
		
	61: IF NOT MAIN_VISION.fbOutfeedCam.bPalletRow2NotClear THEN // LISÄÄ fbMeca500.bExecuteNeedleTest := TRUE;	
			Trig.bRejectCam := TRUE;
			RejectLight(IN := TRUE);
			iProductionMainStep := 62;
		ELSE
			iProductionMainStep := 68;
		END_IF
	62: IF MAIN_VISION.fbRejectCam.bImagingDone THEN
			iProductionMainStep := 63;
			RejectLight(IN := FALSE);
			Trig.bRejectCam := FALSE;
		ELSIF MAIN_VISION.fbRejectCam.bError THEN
			iProductionMainStep := 68;
		END_IF
	63: IF NOT MAIN_VISION.fbRejectCam.bPalletRow2NotClear THEN // LISÄÄ 		
			fbMeca500.bExecuteNeedleTest := TRUE;	
			iProductionMainStep := 64;
		ELSE
			iProductionMainStep := 68;
		END_IF
	64: IF bNeedleSucceeded (*AND MAIN_VISION.stPalletPosData.bMirrorPalletImagingSucceeded *)THEN
			iProductionMainStep := iStepPosSave;
		ELSIF fbMeca500.bNeedleFailed THEN
			iProductionMainStep := 68;
		END_IF
		
	68:	iProductionMainStep := iStepPosSave-1;
		OutfeedLight(IN := FALSE);
		RejectLight(IN := FALSE);
		bAllowStationPrductionStart6To10 := FALSE; 
		stModuleHmi.bProductionStart6To10 := FALSE;
		Err.Err; // 404
		
END_CASE

IF stModuleHmi.bModuleProductionStop THEN
	iProductionMainStep := 30;
END_IF




////STATIONS
stStation.fbSts1(iStationId := 1, 
	stMirrorData := MAIN_VISION.stMirrorDataSts1, 
	stLaserData := StAngleData.stLaserData1,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bActivateStation := stModuleHmi.Stations.bActivateStation1,
	bAllowStart := bAllowStationPrductionStart1To5,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders1,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime1,
	bTrigAngCam => stAssemblyData.Station1To5.bTrigCam1);

stStation.fbSts2(iStationId := 2, 
	stMirrorData := MAIN_VISION.stMirrorDatasts2, 
	stLaserData := StAngleData.stLaserData2,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart1To5,
	bActivateStation := stModuleHmi.Stations.bActivateStation2,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders2,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime2,
	bTrigAngCam => stAssemblyData.Station1To5.bTrigCam2);
	
stStation.fbSts3(iStationId := 3, 
	stMirrorData := MAIN_VISION.stMirrorDatasts3, 
	stLaserData := StAngleData.stLaserData3,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart1To5,
	bActivateStation := stModuleHmi.Stations.bActivateStation3,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders3,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime3,
	bTrigAngCam => stAssemblyData.Station1To5.bTrigCam3);

stStation.fbSts4(iStationId := 4, 
	stMirrorData := MAIN_VISION.stMirrorDatasts4, 
	stLaserData := StAngleData.stLaserData4,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart1To5,
	bActivateStation := stModuleHmi.Stations.bActivateStation4,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders4,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime4,
	bTrigAngCam => stAssemblyData.Station1To5.bTrigCam4);
	
stStation.fbSts5(iStationId := 5, 
	stMirrorData := MAIN_VISION.stMirrorDatasts5, 
	stLaserData := StAngleData.stLaserData5,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart1To5,
	bActivateStation := stModuleHmi.Stations.bActivateStation5,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders5,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime5,
	bTrigAngCam => stAssemblyData.Station1To5.bTrigCam5);
	
stStation.fbSts6(iStationId := 6, 
	stMirrorData := MAIN_VISION.stMirrorDatasts6, 
	stLaserData := StAngleData.stLaserData6,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart6To10,
	bActivateStation := stModuleHmi.Stations.bActivateStation6,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders6,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime6,
	bTrigAngCam => stAssemblyData.Station5To10.bTrigCam6);
	
stStation.fbSts7(iStationId := 7, 
	stMirrorData := MAIN_VISION.stMirrorDatasts7, 
	stLaserData := StAngleData.stLaserData7,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart6To10,
	bActivateStation := stModuleHmi.Stations.bActivateStation7,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders7,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime7,
	bTrigAngCam => stAssemblyData.Station5To10.bTrigCam7);
	
stStation.fbSts8(iStationId := 8, 
	stMirrorData := MAIN_VISION.stMirrorDatasts8, 
	stLaserData := StAngleData.stLaserData8,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart6To10,
	bActivateStation := stModuleHmi.Stations.bActivateStation8,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders8,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime8,
	bTrigAngCam => stAssemblyData.Station5To10.bTrigCam8);
	
stStation.fbSts9(iStationId := 9, 
	stMirrorData := MAIN_VISION.stMirrorDatasts9, 
	stLaserData := StAngleData.stLaserData9,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart6To10,
	bActivateStation := stModuleHmi.Stations.bActivateStation9,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders9,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime9,
	bTrigAngCam => stAssemblyData.Station5To10.bTrigCam9);
	
stStation.fbSts10(iStationId := 10, 
	stMirrorData := MAIN_VISION.stMirrorDatasts10, 
	stLaserData := StAngleData.stLaserData10,
	stModuleHmi := stModuleHmi, 
	stModulePlcCom := stPlcCom,
	bAllowStart := bAllowStationPrductionStart6To10,
	bActivateStation := stModuleHmi.Stations.bActivateStation10,
	bReleaseHolders := stModuleHmi.Stations.bReleaseHolders10,
	sTimeLeft => stModuleHmi.Stations.tAssemmblyTime10,
	bTrigAngCam => stAssemblyData.Station5To10.bTrigCam10);










]]></ST>
    </Implementation>
    <Folder Name="Act" Id="{5bf345b5-e011-4f3f-8746-c0c67f374b28}" />
    <Folder Name="Mthd" Id="{6aab6030-6c86-46e4-a903-25ca2039f43e}" />
    <Action Name="Check1To5AssemblyState" Id="{aea63872-3d6f-4139-a869-987d312d3f5c}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[
	CASE iCheckStep OF
		0: iCheckStep := 1;

		1:	IF stModuleHmi.Stations.bActivateStation1 THEN
					iCheckStep := 2;
			END_IF
		2:	IF stModuleHmi.Stations.bActivateStation2 THEN
				iCheckStep := 3;
			END_IF
		3:	IF stModuleHmi.Stations.bActivateStation3 THEN
					iCheckStep := 4;
			END_IF
		4:	IF stModuleHmi.Stations.bActivateStation4 THEN
					iCheckStep := 5;
			END_IF
		5:	IF stModuleHmi.Stations.bActivateStation5 THEN
					iCheckStep := 11;
			END_IF
			
		6:	IF stModuleHmi.Stations.bActivateStation6 THEN
					iCheckStep := 7;
			END_IF
		7:	IF stModuleHmi.Stations.bActivateStation7 THEN
					iCheckStep := 8;
			END_IF
		8:	IF stModuleHmi.Stations.bActivateStation8 THEN
					iCheckStep := 9;
			END_IF
		9:	IF stModuleHmi.Stations.bActivateStation9 THEN
					iCheckStep := 10;
			END_IF
		10: IF stModuleHmi.Stations.bActivateStation10 THEN
					iCheckStep := 11;
			END_IF
		11: bAssemblyDone := TRUE;
			iCheckStep := 0;
			
	END_CASE
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Check1To5PlacingState" Id="{cdb44b95-2bbf-491e-9a4f-a546f492e733}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[

	CASE iCheckStep OF
		0:	iCheckStep := 1;
		1:	IF stModuleHmi.Stations.bActivateStation1 THEN
				IF stStation.fbSts1.bPlacingDone THEN
					iCheckStep := 2;
				END_IF
			ELSE
					iCheckStep := 2;
			END_IF
		2:	IF stModuleHmi.Stations.bActivateStation2 THEN
				IF stStation.fbSts2.bPlacingDone THEN
					iCheckStep := 3;
				END_IF
			ELSE
					iCheckStep := 3;
			END_IF
		3:	IF stModuleHmi.Stations.bActivateStation3 THEN
				IF stStation.fbSts3.bPlacingDone THEN
					iCheckStep := 4;
				END_IF
			ELSE
					iCheckStep := 4;
			END_IF
		4:	IF stModuleHmi.Stations.bActivateStation4 THEN
				IF stStation.fbSts4.bPlacingDone THEN
					iCheckStep := 5;
				END_IF
			ELSE
					iCheckStep := 5;
			END_IF
			
		5:	IF stModuleHmi.Stations.bActivateStation5 THEN
