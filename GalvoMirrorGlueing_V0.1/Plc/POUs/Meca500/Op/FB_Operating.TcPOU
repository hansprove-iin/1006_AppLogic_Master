<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_Operating" Id="{cb20d2d7-f855-4aae-b705-a3965881f189}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Operating
VAR_IN_OUT
	bRobotHomed : BOOL;
END_VAR
VAR_INPUT
	rJogSpeed : REFERENCE TO REAL;
	stStation	: REFERENCE TO ST_Stations;
	stAssemblyData : REFERENCE TO ST_Recipes;
	stModuleHmi : REFERENCE TO ST_ModuleHmi;
	bExecutePlacing : BOOL;
	stTipOffsets	: REFERENCE TO ST_GluetipCoordinates;
	stPlcCom	: REFERENCE TO ST_Module_PlcCom;
	fbLinearAxis : REFERENCE TO FB_linearAxisFunctions;
	aOffsetsToGlueTip : ARRAY [0..1] OF REAL;
	stCouplerData : REFERENCE TO ST_CouplerImagingData;
	bNewPlacingActive : REFERENCE TO BOOL;
END_VAR
VAR_OUTPUT
	bThicknessTestFailed : BOOL;
	bError : BOOL;
	iWorkingStation	: INT;
	bOperatingActive : BOOL;
	bDismountingActive : BOOL;
END_VAR
VAR
	Sent				: BOOL;
	Buffered			: BOOL;
	Error				: BOOL;
	
	Delay				:Meca500_Delay;
	Gripper				:Meca500_Gripper;
	MoveGripper			:Meca500_MoveGripper;
	MoveJoints			:Meca500_MoveJoints;
	MoveJointsRel		:Meca500_MoveJointsRel;
	MovejointsVel		:Meca500_MoveJointsVel;
	MoveLin				:Meca500_MoveLin;
	MoveLinRelTrf		:Meca500_MoveLinRelTrf;
	MoveLinRelWrf		:Meca500_MoveLinRelWrf;
	MoveLinVelTrf		:Meca500_MoveLinVelTrf;
	MoveLinVelWrf		:Meca500_MoveLinVelWrf;
	MovePose			:Meca500_MovePose;
	SetAutoConf			:Meca500_SetAutoConf;
	SetAutoConfTurn		:Meca500_SetAutoConfTurn;
	SetBlending			:Meca500_SetBlending;
	SetCartAcc			:Meca500_SetCartAcc;
	SetCartAngVel		:Meca500_SetCartAngVel;
	SetCartLinVel		:Meca500_SetCartLinVel;
	SetCheckpoint		:Meca500_SetCheckpoint;
	SetConf				:Meca500_SetConf;
	SetConfTurn			:Meca500_SetConfTurn;
	SetGripperForce		:Meca500_SetGripperForce;
	SetGripperRange		:Meca500_SetGripperRange;
	SetGripperVel		:Meca500_SetGripperVel;
	SetJointAcc			:Meca500_SetJointAcc;
	SetJointVel			:Meca500_SetJointVel;
	SetTorqueLimitCfg	:Meca500_SetTorqueLimitCfg;
	SetTorqueLimits		:Meca500_SetTorqueLimits;
	SetTrf				:Meca500_SetTrf;
	SetValveState		:Meca500_SetValveState;
	SetVelTimeout		:Meca500_SetVelTimeout;
	SetWrf				:Meca500_SetWrf;
	StartProgram		:Meca500_StartProgram;
	SetJointVelLimit	:Meca500_SetJointVelLimit;
	SetTimeScaling		:Meca500_SetTimeScaling;
	GetEOAT 			:Meca500_GetEOAT;
	EOAT				: ARRAY [0..5] OF REAL; // Values: [holding part, desired fingers opening reached, gripper closed, gripper open, gripper force, fingers opening].
	stStationPoses		: ST_Sts_PoseData;
	iOperatingStep 		: INT;
	iMirrorStep			: INT;
	iFinishedStep		: INT;
	OperatingState		: E_OperatingState;
	
	PoseTRFMirror		: ARRAY [1..6] OF REAL := [0,0,106.6,0,0,0];
	PoseTRFMotor		: ARRAY [1..6] OF REAL := [0,0,98.6,0,0,0];
	PoseHome			: ARRAY [1..6] OF REAL := [-90,0,0,0,90,0];
	PoseHome1			: ARRAY [1..6] OF REAL := [-90,0,0,0,90,0];
	PoseHome2			: ARRAY [1..6] OF REAL := [90,0,0,0,90,0];
	PoseImagingGalvo14mm		: ARRAY [1..6] OF REAL := [-174.4306, 132.6053 , 214, 180, -90 , 0]; // Initial Pose before motor type based correct imaging pose
	PoseImagingGalvo10mm		: ARRAY [1..6] OF REAL := [-174.4306, 132.6053 , 226.5, 180, -90 , 0]; // Final pose related to motor and coupler type
	
	PoseSafeInOutGlueSt1	:  ARRAY [1..6] OF REAL := [-134 , 100 ,  177.9, -180 , -70 , 0 ]; // '
	PoseSafeInOutGlueSt2	:  ARRAY [1..6] OF REAL := [162.3 , 4.2 , 36 , 88 ,  -43.5, -57]; // JOINT VALUES '
	PoseSafeInOutGlueSt3	:  ARRAY [1..6] OF REAL := [-185, 154 , 73 , -155, -10, 70]; //'
	PoseAfterGluingSt1		:  ARRAY [1..6] OF REAL := [120 , 0 , 0, 0 ,  90, 0]; // JOINT VALUES'
	PoseGluingSt1		:  ARRAY [1..6] OF REAL := [-170.1, 134 ,165.7  , -167.5 , -4.7 , 72.5]; // 
	PoseGluingSt2 		:  ARRAY [1..6] OF REAL := [-175, 166 ,177.87  , -163.5 , -7.2 , 73.2]; // 
	PoseGluingSt3 		:  ARRAY [1..6] OF REAL := [-175, 166 ,160.27  , -163.5 , -7.2 , 73.2]; // 
	PoseGluingSt4 		:  ARRAY [1..6] OF REAL := [-157.9, 103.5 ,160.5  , -163.5 , -7.2 , 73.2]; // 
	PoseGluingSt5		:  ARRAY [1..6] OF REAL := [ -173.55, 132.8, 103 , -123.6 , -17 , 90];  // 
	
	PoseGluingSt6 		:  ARRAY [1..6] OF REAL := [ -169.673813, 134.421356, 118.048595 , -123.6 , -17 , 90]; // 
	PoseGluingSt7 		:  ARRAY [1..6] OF REAL := [ -173.192612,132.9314, 118.355591 , -123.600 , -17 , 90];  //
	PoseGluingSt8		:  ARRAY [1..6] OF REAL := [ -174.150, 132.583 , 83.690 , -106.182 , -17 , 90];   //
	PoseGluingSt9		:  ARRAY [1..6] OF REAL := [ -169.879,134.182,83.645,-106.182,-17,90];  //
	PoseGluingSt10		:  ARRAY [1..6] OF REAL := [ -169.879,134.697,77,-106.182,-17,90];  //
	
	PoseMotorPickupSt1	: ARRAY [1..6] OF REAL := [-107.6,-150.45 , 110.5 , 0, -90 ,0]; // POSE BEFORE ACTUAL GRIP POSITION
	PoseMotorPickupSt2	: ARRAY [1..6] OF REAL := [-127.65,-150.45 , 110.5 , 0, -90 ,0];// ACTUAL GRIP POSITION
	PoseMotorPickupSt3	: ARRAY [1..6] OF REAL := [-127.65,-150.45 , 200.5 , 0, -90 ,0];// MOTOR LIFT FROM PALLET
	
	PoseMotorPlaceSt1	: ARRAY [1..6] OF REAL := [-73.5605, 110 ,165.6645  , -180 , 0 , 90]; // POSE BEFORE ACTULA LEAVING POSITION
	PoseMotorPlaceSt2	: ARRAY [1..6] OF REAL := [-73.5605, 140 ,165.6645  , -180 , 0 , 90]; // ACTUAL POSITION FOR LEAVING MOTOR AT CURING STATION
	PoseMotorPlaceSt3	: ARRAY [1..6] OF REAL := [-73.5605, 140 ,200  , -180 , 0 , 90]; // POSE AFTER LEAVING MOTOR AT CURING STATION
	
	PoseMirrorPickupSt1	: ARRAY [1..6] OF REAL := [-158.5,-91.5 , 200 ,180, 0 ,0]; // POSE BEFORE ACTUAL GRIP POSITION
	PoseMirrorPickupSt2	: ARRAY [1..6] OF REAL := [-158.5,-91.5 , 187.1757 ,180, 0 ,0];// ACTUAL GRIP POSITION
	
	PoseMirrorAdjust	: ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90]; // POSE BEFORE INSERTIN MIRROR IN STATION
	PoseMirrorAdjustPrev : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90]; // POSE LAST ADJUSTMENT POSE
	PoseMirrorAdjustPrevSts1 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts2 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts3 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts4 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts5 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts6 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts7 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts8 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts9 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMirrorAdjustPrevSts10 : ARRAY [1..6] OF REAL := [-71.6, 192.8 ,200.3  , -180 , 0 , 90];
	PoseMotorPickupTemp : ARRAY [1..6] OF REAL := [-73.2067 , 21.8881 , 23.8300 , -105.4797 , 75.4102 , -42.2884]; // JOINT VALUES
	PoseToGluing			: ARRAY [1..6] OF REAL := [173 , 6 , 35 , 95 ,  -50, -57]; // JOINT VALUES
	PoseToMirrorPickupSt1 : ARRAY [1..6] OF REAL := [154 , 0 , 0 , 0 ,  90, 0]; // JOINT VALUES
	
	GluingTmr1			: TON;
	GluingTmr2			: TON;
	GluingStartTmr		: TON;
	GluingOffTmr		: TON;
	GluingStartTmr2		: TON;
	StationGripperTmr	: TON;
	ReleaseTmr			: TON;
	bLinearAxisDone		: BOOL;
	iStationSelect		: INT;
	iGluingPoses		: INT;
	iGluingStep			: INT;
	bMotorType 			: BOOL; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
	bBypassState		: BOOL; // Used to skip if function that controls operatingstep
	iGluingTimeLine		: UDINT;
	iGluingTimeDot		: UDINT;
	stGluingPoses		: ST_GluingPoses;
	rAngleErrHeight		: REAL;
	rAngleErrPos		: REAL;
	rCouplerOffset 		: REAL;
	eCurrentState		: E_CurrentState;
	bProductPassed		: BOOL;
	bHolderSensor		: BOOL;
	bSliderSensor		: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[GluingTmr1(PT := UDINT_TO_TIME (iGluingTimeDot * 1000)); // GLUING ON TIMER FOR DOT
GluingTmr2(PT := UDINT_TO_TIME (iGluingTimeLine * 1000)); // GLUING ON TIMER FOR LINE
GluingOffTmr(PT := T#7S); // Timer for wait time after gluing.
GluingStartTmr2(PT := T#5S); // Timer for wait before line gluing movement start
StationGripperTmr(PT := T#1S); // Timer for wait for gripper movement


CASE OperatingState OF
	E_OperatingState.Init:
		Initialize();	
		IF bExecutePlacing THEN
			OperatingState := E_OperatingState.SetPoses;
		END_IF
	E_OperatingState.SetPoses:
		eCurrentState := E_CurrentState.Init;
		bOperatingActive := FALSE;
		CASE iStationSelect OF
			0: iStationSelect := 1; // NO STATION SELECTED
			1: IF stStation.fbSts1.bInHoldForRobot THEN
					CheckType();
					WritePoses(iStationId := 1); // Write robot ready for station
					iWorkingStation := 1;
					stStation.fbSts1.bRobotReadyForStation := TRUE;
					bExecutePlacing := TRUE;
					IF NOT stStation.fbSts1.MotorInStation THEN
						iOperatingStep := 0;
						IF NOT bMotorType THEN	
							OperatingState := E_OperatingState.OperatingGalvo14mm;
						ELSE
							OperatingState := E_OperatingState.OperatingGalvo10mm;
						END_IF
					ELSIF stStation.fbSts1.AllPartsInStation AND NOT stStation.fbSts1.AssemblyDone THEN
						iMirrorStep := 0;
						OperatingState := E_OperatingState.MirrorAdjustment;
					ELSIF stStation.fbSts1.AssemblyDone AND NOT bNewPlacingActive THEN
						iOperatingStep := 0;
						IF NOT bMotorType THEN	
							OperatingState := E_OperatingState.FinishedHandling14mm;
						ELSE
							OperatingState := E_OperatingState.FinishedHandling10mm;
						END_IF
					ELSIF NOT stStation.fbSts1.bHoldRobotForAdj THEN
						iStationSelect := 2;
					END_IF
 				ELSIF stStation.fbSts1.bHoldRobotForAdj THEN
 					stStation.fbSts1.bRobotReadyForStation := FALSE;
				ELSE
					stStation.fbSts1.bRobotReadyForStation := FALSE;
					iStationSelect := 2;
				END_IF
			2: IF stStation.fbSts2.bInHoldForRobot THEN
					CheckType();
					WritePoses(iStationId := 2); // Write robot ready for station
					iWorkingStation := 2;
					stStation.fbSts2.bRobotReadyForStation := TRUE;
					bExecutePlacing := TRUE;
					IF NOT stStation.fbSts2.MotorInStation THEN
						iOperatingStep := 0;
						IF NOT bMotorType THEN	
							OperatingState := E_OperatingState.OperatingGalvo14mm;
						ELSE
							OperatingState := E_OperatingState.OperatingGalvo10mm;
						END_IF
					ELSIF stStation.fbSts2.AllPartsInStation AND NOT stStation.fbSts2.AssemblyDone THEN
						iMirrorStep := 0;
						OperatingState := E_OperatingState.MirrorAdjustment;
					ELSIF stStation.fbSts2.AssemblyDone AND NOT bNewPlacingActive THEN
						iOperatingStep := 0;
						IF NOT bMotorType THEN	
							OperatingState := E_OperatingState.FinishedHandling14mm;
						ELSE
							OperatingState := E_OperatingState.FinishedHandling10mm;
						END_IF
					ELSE
						iStationSelect := 0;
					END_IF
 				ELSIF stStation.fbSts2.bHoldRobotForAdj THEN
 					stStation.fbSts2.bRobotReadyForStation := FALSE;
				ELSE
					stStation.fbSts2.bRobotReadyForStation := FALSE;
					iStationSelect := 0;
				END_IF
		END_CASE
	
		
	E_OperatingState.MoveLinAxis:
		bOperatingActive := TRUE;
		IF NOT fbLinearAxis.LinearAxisBusy THEN
			fbLinearAxis.ExecuteMovement := TRUE;
		END_IF
		IF fbLinearAxis.bMovementDone THEN
			fbLinearAxis.ExecuteMovement := FALSE;
			bLinearAxisDone := TRUE;
			IF eCurrentState = E_CurrentState.GalvoHandling THEN
				IF bMotorType THEN
					OperatingState := E_OperatingState.OperatingGalvo10mm;
				ELSE
					OperatingState := E_OperatingState.OperatingGalvo14mm;
				END_IF
			ELSIF  eCurrentState = E_CurrentState.MirrorAdj THEN
				OperatingState := E_OperatingState.MirrorAdjustment;
			ELSIF  eCurrentState = E_CurrentState.FinishedProduct THEN
				IF bMotorType THEN
					OperatingState := E_OperatingState.FinishedHandling10mm;
				ELSE
					OperatingState := E_OperatingState.FinishedHandling14mm;
				END_IF
			END_IF
			
		END_IF
		
	E_OperatingState.OperatingGalvo14mm:  // LISÄÄ KOHTA JOKA PITÄÄ HUOLEN ETTÄ JOS ANTURI TUNNISTAA VÄÄRÄSSÄ PAIKKAA ROBOTIN ON PYSÄHDYTTÄVÄ
 		Galvo14mm();
	
	E_OperatingState.OperatingGalvo10mm: ; // MUISTA PIENEN PEILIN KORJAUKSESSA SLIDERIN SIJAINTI
		
		
	E_OperatingState.MirrorAdjustment:
 		MirrorAdj();
		
	E_OperatingState.FinishedHandling14mm:
		bDismountingActive := TRUE;
		Finished14mm();
		
	E_OperatingState.FinishedHandling10mm:
		bDismountingActive := TRUE;
	
END_CASE


GetEOAT(
	Status => EOAT,
	Robot := Meca500.GVL.Meca500);]]></ST>
    </Implementation>
    <Folder Name="Act" Id="{fbbec362-08eb-40d4-b222-e2740caef989}" />
    <Folder Name="Mth" Id="{417f24a5-3b5e-420c-a919-64423eab2c88}" />
    <Method Name="AdjDone" Id="{ccf00eb9-e52d-4e13-9f7e-5744fa517659}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD AdjDone : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	0:
	1: PoseMirrorAdjustPrevSts1 :=PoseMirrorAdjust;
	stStation.fbSts1.bAdjDone := TRUE;
	2:  PoseMirrorAdjustPrevSts2 :=PoseMirrorAdjust;
	stStation.fbSts2.bAdjDone := TRUE;
	3:  PoseMirrorAdjustPrevSts3 :=PoseMirrorAdjust;
	stStation.fbSts3.bAdjDone := TRUE;
	4:  PoseMirrorAdjustPrevSts4 :=PoseMirrorAdjust;
	stStation.fbSts4.bAdjDone := TRUE;
	5:  PoseMirrorAdjustPrevSts5 :=PoseMirrorAdjust;
	stStation.fbSts5.bAdjDone := TRUE;
	6:  PoseMirrorAdjustPrevSts6 :=PoseMirrorAdjust;
	stStation.fbSts6.bAdjDone := TRUE;
	7:  PoseMirrorAdjustPrevSts7 :=PoseMirrorAdjust;
	stStation.fbSts7.bAdjDone := TRUE;
	8:  PoseMirrorAdjustPrevSts8 :=PoseMirrorAdjust;
	stStation.fbSts8.bAdjDone := TRUE;
	9:  PoseMirrorAdjustPrevSts9 :=PoseMirrorAdjust;
	stStation.fbSts9.bAdjDone := TRUE;
	10:  PoseMirrorAdjustPrevSts10 :=PoseMirrorAdjust;
	stStation.fbSts10.bAdjDone := TRUE;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="CheckProduct" Id="{04076697-36a3-4c55-b410-5e8547b43894}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD CheckProduct : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	0:
	1:IF stStation.fbSts1.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	2:IF stStation.fbSts2.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	3:IF stStation.fbSts3.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	4:IF stStation.fbSts4.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	5:IF stStation.fbSts5.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	6:IF stStation.fbSts6.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	7:IF stStation.fbSts7.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	8:IF stStation.fbSts8.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	9:IF stStation.fbSts9.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	10:IF stStation.fbSts10.bAssemblyFailed THEN
			bProductPassed := FALSE;
		ELSE
			bProductPassed := TRUE;
		END_IF
	
	
	
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="CheckType" Id="{8d7e3152-2bba-40d1-9708-3b600a5e1cec}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD CheckType : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	1..5: 
		IF stAssemblyData.Station1To5.sAssemblyType = 'AL-86068' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-79710' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-82028' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
			
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-82026' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
			rCouplerOffset := 0;										// Coupler offset means how deep mirror placement needs to go related to coupler depth 12.6 other is 10.2
			rAngleErrHeight := ((6/2)*SIN(stCouplerData.rCouplerAngleRad))+(0.89)*(COS(stCouplerData.rCouplerAngleRad)-0.89); // Calculates te coupler angles inpact on gluing position (CouplerThickness/2)...(CouplerGluing surface offset from center)
			rAngleErrPos := (3-((6/2)*COS(stCouplerData.rCouplerAngleRad))-((0.89)*SIN(stCouplerData.rCouplerAngleRad)));
			PoseGluingSt1 := stGluingPoses.AL82027.PoseGluingSt1;
			PoseGluingSt2 := stGluingPoses.AL82027.PoseGluingSt2;
			PoseGluingSt3 := stGluingPoses.AL82027.PoseGluingSt3;
			PoseGluingSt4 := stGluingPoses.AL82027.PoseGluingSt4;
			
			PoseGluingSt2[1] := PoseGluingSt2[1] - stTipOffsets.X;
			PoseGluingSt2[2] := PoseGluingSt2[2] - stTipOffsets.Y;
			
			PoseGluingSt3[1] := PoseGluingSt3[1] - stTipOffsets.X;
			PoseGluingSt3[2] := PoseGluingSt3[2] - stTipOffsets.Y;
			
			PoseGluingSt4[1] := PoseGluingSt4[1] - stTipOffsets.X;
			PoseGluingSt4[2] := PoseGluingSt4[2] - stTipOffsets.Y;
			
			PoseGluingSt5[1] := PoseGluingSt5[1] - stTipOffsets.X;
			PoseGluingSt5[2] := PoseGluingSt5[2] - stTipOffsets.Y;
			
 			iGluingTimeLine := stGluingPoses.AL82027.iGluingTimeLine;
 			iGluingTimeDot := stGluingPoses.AL82027.iGluingTimeDot;
			
			IF stCouplerData.rCouplerAngleDeg > 0 THEN
				PoseGluingSt2[3] := PoseGluingSt2[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt3[3] := PoseGluingSt3[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt4[3] := PoseGluingSt4[3] - stTipOffsets.Z + rAngleErrHeight;
			ELSE
				PoseGluingSt2[3] := PoseGluingSt2[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt3[3] := PoseGluingSt3[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt4[3] := PoseGluingSt4[3] - stTipOffsets.Z - rAngleErrHeight;
			END_IF
			iGluingPoses := stGluingPoses.AL82027.iPoseAmount;
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-69219' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm	
	
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-70918' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200617' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200613' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-88450' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200665' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200663' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-82029' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-86069' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-79420' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-82027' THEN
			rCouplerOffset := 0;										// Coupler offset means how deep mirror placement needs to go related to coupler height 12.6
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
			rAngleErrHeight := ((6/2)*SIN(stCouplerData.rCouplerAngleRad))+(0.89)*(COS(stCouplerData.rCouplerAngleRad)-0.89); // Calculates te coupler angles inpact on gluing position (CouplerThickness/2)...(CouplerGluing surface offset from center)
			PoseGluingSt1 := stGluingPoses.AL82027.PoseGluingSt1;
			PoseGluingSt2 := stGluingPoses.AL82027.PoseGluingSt2;
			PoseGluingSt3 := stGluingPoses.AL82027.PoseGluingSt3;
			PoseGluingSt4 := stGluingPoses.AL82027.PoseGluingSt4;
			
			PoseGluingSt2[1] := PoseGluingSt2[1] - stTipOffsets.X;
			PoseGluingSt2[2] := PoseGluingSt2[2] - stTipOffsets.Y;
			
			PoseGluingSt3[1] := PoseGluingSt3[1] - stTipOffsets.X;
			PoseGluingSt3[2] := PoseGluingSt3[2] - stTipOffsets.Y;
			
			PoseGluingSt4[1] := PoseGluingSt4[1] - stTipOffsets.X;
			PoseGluingSt4[2] := PoseGluingSt4[2] - stTipOffsets.Y;
			
			PoseGluingSt5[1] := PoseGluingSt5[1] - stTipOffsets.X;
			PoseGluingSt5[2] := PoseGluingSt5[2] - stTipOffsets.Y;
			
			iGluingTimeLine := stGluingPoses.AL82027.iGluingTimeLine;
			iGluingTimeDot := stGluingPoses.AL82027.iGluingTimeDot;
			IF stCouplerData.rCouplerAngleDeg > 0 THEN
				PoseGluingSt2[3] := PoseGluingSt2[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt3[3] := PoseGluingSt3[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt4[3] := PoseGluingSt4[3] - stTipOffsets.Z + rAngleErrHeight;
			ELSE
				PoseGluingSt2[3] := PoseGluingSt2[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt3[3] := PoseGluingSt3[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt4[3] := PoseGluingSt4[3] - stTipOffsets.Z - rAngleErrHeight;
			END_IF
			iGluingPoses := stGluingPoses.AL82027.iPoseAmount;
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-69220' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-70916' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200618' THEN
			bMotorType := TRUE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200614' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-88470' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
		
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200662' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
			rCouplerOffset := 2.4;
			rAngleErrHeight := ((6/2)*SIN(stCouplerData.rCouplerAngleRad))+(0.89)*(COS(stCouplerData.rCouplerAngleRad)-0.89); // Calculates te coupler angles inpact on gluing position (CouplerThickness/2)...(CouplerGluing surface offset from center)
			PoseGluingSt1 := stGluingPoses.AL200662.PoseGluingSt1;
			PoseGluingSt2 := stGluingPoses.AL200662.PoseGluingSt2;
			PoseGluingSt3 := stGluingPoses.AL200662.PoseGluingSt3;
			PoseGluingSt4 := stGluingPoses.AL200662.PoseGluingSt4;
			PoseGluingSt5 := stGluingPoses.AL200662.PoseGluingSt5;
			
			PoseGluingSt2[1] := PoseGluingSt2[1] - stTipOffsets.X;
			PoseGluingSt2[2] := PoseGluingSt2[2] - stTipOffsets.Y;
			
			PoseGluingSt3[1] := PoseGluingSt3[1] - stTipOffsets.X;
			PoseGluingSt3[2] := PoseGluingSt3[2] - stTipOffsets.Y;
			
			PoseGluingSt4[1] := PoseGluingSt4[1] - stTipOffsets.X;
			PoseGluingSt4[2] := PoseGluingSt4[2] - stTipOffsets.Y;
			
			PoseGluingSt5[1] := PoseGluingSt5[1] - stTipOffsets.X;
			PoseGluingSt5[2] := PoseGluingSt5[2] - stTipOffsets.Y;
			
			IF stCouplerData.rCouplerAngleDeg > 0 THEN
				PoseGluingSt2[3] := PoseGluingSt2[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt3[3] := PoseGluingSt3[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt4[3] := PoseGluingSt4[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt5[3] := PoseGluingSt5[3] - stTipOffsets.Z + rAngleErrHeight;
			ELSE
				PoseGluingSt2[3] := PoseGluingSt2[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt3[3] := PoseGluingSt3[3] - stTipOffsets.Z + rAngleErrHeight;
				PoseGluingSt4[3] := PoseGluingSt4[3] - stTipOffsets.Z - rAngleErrHeight;
				PoseGluingSt5[3] := PoseGluingSt5[3] - stTipOffsets.Z - rAngleErrHeight;
			END_IF
			iGluingPoses := 5;
			
		ELSIF stAssemblyData.Station1To5.sAssemblyType = 'AL-200664' THEN
			bMotorType :=FALSE; // IF TRUE THEN MOTOR TYPE IS 10mm, FALSE IS 14mm
			PoseGluingSt1 := stGluingPoses.AL200662.PoseGluingSt1;
			PoseGluingSt2 := stGluingPoses.AL200662.PoseGluingSt2;
			PoseGluingSt3 := stGluingPoses.AL200662.PoseGluingSt3;
			PoseGluingSt4 := stGluingPoses.AL200662.PoseGluingSt4;
			PoseGluingSt5 := stGluingPoses.AL200662.PoseGluingSt5;
			iGluingPoses := 5;
		END_IF;

// 	5..10: 
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="DisableSetStation" Id="{1df013af-16bc-43b7-90ef-e92dda3557f5}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD DisableSetStation : BOOL
