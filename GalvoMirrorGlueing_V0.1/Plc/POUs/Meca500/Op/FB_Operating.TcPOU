		END_IF
	2: stStation.fbSts2.bEngageSlider := FALSE;
		IF stStation.fbSts2.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	3: stStation.fbSts3.bEngageSlider := FALSE;
		IF stStation.fbSts3.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	4: stStation.fbSts4.bEngageSlider := FALSE;
		IF stStation.fbSts4.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	5: stStation.fbSts5.bEngageSlider := FALSE;
		IF stStation.fbSts5.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	6: stStation.fbSts6.bEngageSlider := FALSE;
		IF stStation.fbSts6.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	7: stStation.fbSts7.bEngageSlider := FALSE;
		IF stStation.fbSts7.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	8: stStation.fbSts8.bEngageSlider := FALSE;
		IF stStation.fbSts8.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	9: stStation.fbSts9.bEngageSlider := FALSE;
		IF stStation.fbSts9.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
	10: stStation.fbSts10.bEngageSlider := FALSE;
		IF stStation.fbSts10.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
			bSliderSensor := TRUE;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetAdjustmentPoses" Id="{075017d8-2792-4614-9697-ca6eae04e726}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD SetAdjustmentPoses : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	1: IF stStation.fbSts1.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust[1] := stStationPoses.aPoseMirrorPlaceSt3[1] + stStation.fbSts1.rRobotAdjValue;

		ELSE
			PoseMirrorAdjustPrev := PoseMirrorAdjustPrevSts1;
			PoseMirrorAdjust := PoseMirrorAdjustPrevSts1;
			PoseMirrorAdjust[1] := PoseMirrorAdjustPrevSts1[1] + stStation.fbSts1.rRobotAdjValue;
		END_IF
	2: IF stStation.fbSts2.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust[1] := stStationPoses.aPoseMirrorPlaceSt3[1] + stStation.fbSts2.rRobotAdjValue;
		ELSE
			PoseMirrorAdjustPrev := PoseMirrorAdjustPrevSts2;
			PoseMirrorAdjust := PoseMirrorAdjustPrevSts2;
			PoseMirrorAdjust[1] := PoseMirrorAdjustPrevSts2[1] + stStation.fbSts2.rRobotAdjValue;
		END_IF
		
	3:  IF stStation.fbSts3.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust[2] := stStationPoses.aPoseMirrorPlaceSt3[2] + stStation.fbSts3.rRobotAdjValue;
		ELSE
			PoseMirrorAdjustPrev := PoseMirrorAdjustPrevSts3;
			PoseMirrorAdjust := PoseMirrorAdjustPrevSts3;
			PoseMirrorAdjust[2] := PoseMirrorAdjustPrevSts3[2] - stStation.fbSts3.rRobotAdjValue;
		END_IF
	4:  IF stStation.fbSts4.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust[2] := stStationPoses.aPoseMirrorPlaceSt3[2] + stStation.fbSts4.rRobotAdjValue;
		ELSE
			PoseMirrorAdjustPrev := PoseMirrorAdjustPrevSts4;
			PoseMirrorAdjust := PoseMirrorAdjustPrevSts4;
			PoseMirrorAdjust[2] := PoseMirrorAdjustPrevSts4[2] - stStation.fbSts4.rRobotAdjValue;
		END_IF
	5:  IF stStation.fbSts5.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust[2] := stStationPoses.aPoseMirrorPlaceSt3[2] + stStation.fbSts5.rRobotAdjValue;
		ELSE
			PoseMirrorAdjustPrev := PoseMirrorAdjustPrevSts5;
			PoseMirrorAdjust := PoseMirrorAdjustPrevSts5;
			PoseMirrorAdjust[2] := PoseMirrorAdjustPrevSts5[2] - stStation.fbSts5.rRobotAdjValue;
		END_IF
	6:  IF stStation.fbSts6.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust[2] := stStationPoses.aPoseMirrorPlaceSt3[2] + stStation.fbSts6.rRobotAdjValue;
		ELSE
			PoseMirrorAdjustPrev := PoseMirrorAdjustPrevSts6;
			PoseMirrorAdjust := PoseMirrorAdjustPrevSts6;
			PoseMirrorAdjust[2] := PoseMirrorAdjustPrevSts6[2] - stStation.fbSts6.rRobotAdjValue;
		END_IF
	7: IF stStation.fbSts7.iAdjustmentCount < 1 THEN
			PoseMirrorAdjustPrev  := stStationPoses.aPoseMirrorPlaceSt3;
			PoseMirrorAdjust := stStationPoses.aPoseMirrorPlaceSt3;
