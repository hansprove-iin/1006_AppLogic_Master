	7: stStation.fbSts7.bDismountingDone := TRUE;
	8: stStation.fbSts8.bDismountingDone := TRUE;
	9: stStation.fbSts9.bDismountingDone := TRUE;
	10: stStation.fbSts10.bDismountingDone := TRUE;
END_CASE]]></ST>
