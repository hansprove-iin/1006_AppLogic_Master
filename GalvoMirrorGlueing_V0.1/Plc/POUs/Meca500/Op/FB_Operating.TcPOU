			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	4: stStation.fbSts4.bEngageHolder := TRUE;
		IF NOT stStation.fbSts4.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	5: stStation.fbSts5.bEngageHolder := TRUE;
		IF NOT stStation.fbSts5.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	6: stStation.fbSts6.bEngageHolder := TRUE;
		IF NOT stStation.fbSts6.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	7: stStation.fbSts7.bEngageHolder := TRUE;
		IF NOT stStation.fbSts7.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	8: stStation.fbSts8.bEngageHolder := TRUE;
		IF NOT stStation.fbSts8.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	9: stStation.fbSts9.bEngageHolder := TRUE;
		IF NOT stStation.fbSts9.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	10: stStation.fbSts10.bEngageHolder := TRUE;
		IF NOT stStation.fbSts10.bHolderSensor THEN
			bHolderSensor := TRUE;
