		stStationPoses.aPoseMirrorPickupSt2 := stStation.stSts2.aPoseMirrorPickupSt2;
		stStationPoses.aPoseMirrorPlaceSt1 := stStation.stSts2.aPoseG14MirrorPlaceSt1;
