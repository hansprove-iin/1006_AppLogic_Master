    <Action Name="Finished14mm" Id="{90d4519f-ee19-45e8-93b6-61a6b2f8595a}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[eCurrentState := E_CurrentState.FinishedProduct;
bOperatingActive := TRUE;
CASE iFinishedStep OF
	0: iFinishedStep := 1;
		
 	1:	MoveGripper(mm := 24,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	2: SetTrf(
			Pose := PoseTRFMotor,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	3: SetGripperForce(
			Force := 60,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	4: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPlace;
		OperatingState := E_OperatingState.MoveLinAxis;
		iFinishedStep := 5;
	5: IF EOAT[1] = 1 AND EOAT[0] = 0 THEN
			IF iWorkingStation < 5 THEN
				iFinishedStep := 6;
			ELSE
				iFinishedStep := 7;
			END_IF
		END_IF
	6: MoveJoints(Joint_Angle := PoseHome2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	7: iFinishedStep := 9;
	8: MoveJoints(Joint_Angle := PoseHome1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	9: SetCheckpoint(CheckpointID := 20,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	10: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 20 THEN
			iFinishedStep := 11;
		END_IF
	11: MovePose(Pose := stStationPoses.aPoseLargeMotorPlaceSt3,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	12: MoveLin(Pose := stStationPoses.aPoseLargeMotorPlaceSt2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);	
	13: MoveGripper(mm := 0,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	14: SetCheckpoint(CheckpointID := 104,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	
	15: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 104 AND EOAT[0] = 1 THEN
			ReleaseHolder();
			ReleaseSlider();
			CheckProduct();
			ReleaseTmr.IN := TRUE;
			IF ReleaseTmr.Q AND NOT bHolderSensor AND bSliderSensor THEN
				ReleaseTmr.IN := FALSE;
				iFinishedStep := 16;
			END_IF
		END_IF
	16: MoveLin(Pose := stStationPoses.aPoseLargeMotorPlaceSt1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	17: SetCheckpoint(CheckpointID := 204,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	18: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 204 THEN // LISÄÄ TARKISTUS TUOTTEEN LAADUSTA
			IF bProductPassed THEN
				fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPalletPass;
				OperatingState := E_OperatingState.MoveLinAxis;
				iFinishedStep := 19;
			ELSE
				fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPalletReject;
				OperatingState := E_OperatingState.MoveLinAxis;
				iFinishedStep := 100;
			END_IF
		END_IF
	19: IF iWorkingStation < 5 THEN
			iFinishedStep := 20;
		ELSE
			iFinishedStep := 22;
		END_IF
	20: MoveJoints(Joint_Angle := PoseHome2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	21: iFinishedStep := 23;
	22: MoveJoints(Joint_Angle := PoseHome1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	23: MovePose(Pose := stStationPoses.aPosePassedLargeSt1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	24: MoveLin(Pose := stStationPoses.aPosePassedLargeSt2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	25:  MoveLin(Pose := stStationPoses.aPosePassedLargeSt3,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	26:  SetCheckpoint(CheckpointID := 304,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	27: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 304 THEN 
			iFinishedStep := 28;
		END_IF
	28: MoveGripper(mm := 20,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	29: IF EOAT[1] = 1 AND EOAT[0] = 0 THEN
			iFinishedStep := 31;
		END_IF
	31: MoveLin(Pose := stStationPoses.aPosePassedLargeSt2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	32: MovePose(Pose := stStationPoses.aPosePassedLargeSt1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	33: IF iWorkingStation < 5 THEN
			iFinishedStep := 34;
		ELSE
			iFinishedStep := 36;
		END_IF
	34: MoveJoints(Joint_Angle := PoseHome2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	35: iFinishedStep := 37;
	36: MoveJoints(Joint_Angle := PoseHome1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	37: SetCheckpoint(CheckpointID := 124,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	38: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 124 THEN 
			OperatingState := E_OperatingState.SetPoses;
			DismountingDone();
			iFinishedStep := 0;
		END_IF
		
END_CASE
ReleaseTmr( PT := T#1S);
IF Sent AND Buffered THEN
	iFinishedStep := iFinishedStep +1;
	Sent := FALSE;
	Buffered := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Galvo10mm" Id="{28526a0e-eb6d-4d21-9b51-86ca0eddfaa9}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[bOperatingActive := TRUE;
	eCurrentState := E_CurrentState.GalvoHandling;
	CASE iOperatingStep OF
		0: IF bExecutePlacing THEN
				iOperatingStep := 1;
				bExecutePlacing := FALSE;
			END_IF
		1: MoveGripper(mm := 24,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		2: IF EOAT[5] = 24 THEN	
			SetGripperForce(
				Force := 60,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
			END_IF
		3: SetTrf(
				Pose := PoseTRFMotor,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
			
		4: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosMotorPickup;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 5;
		5: MovePose(Pose := stStationPoses.aPoseSmallMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		6: MoveLin(Pose := stStationPoses.aPoseSmallMotorPickupSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		7: SetCheckpoint(CheckpointID := 120,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		8: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 120 THEN
				IF NOT stPlcCom.stPlcComIn.bRobotGripperSensor THEN
					iOperatingStep := 12;
				ELSE
					IF iWorkingStation <= 5 THEN
						PoseHome := PoseHome1;
					ELSE
						PoseHome := PoseHome2;
					END_IF
					iOperatingStep := 9;
				END_IF
			END_IF
		9:  MoveLin(Pose := stStationPoses.aPoseSmallMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		10:  MoveJoints(Joint_Angle := PoseHome,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);		
		11: DisableSetStation(iStationId := iWorkingStation);
			OperatingState := E_OperatingState.SetPoses;
			iOperatingStep := 0;
		12: MoveGripper(mm := 2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		13: SetCheckpoint(CheckpointID := 101,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		14: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 101 AND EOAT[0] = 1 THEN
				IF EOAT[5] > 6.5 AND EOAT[5] < 7 AND NOT bMotorType THEN		
					iOperatingStep := 17;
				ELSE
					iOperatingStep := 15;
					bThicknessTestFailed := TRUE;
				END_IF
			END_IF
		15: MoveGripper(mm := 19,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		16: iOperatingStep := 9;
		17: MoveLin(Pose := stStationPoses.aPoseSmallMotorPickupSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		18: MoveLin(Pose := stStationPoses.aPoseSmallMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		19: SetCheckpoint(CheckpointID := 132,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		20: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 132 THEN
				iOperatingStep := 25;
			END_IF
		25: MovePose(Pose := PoseImagingGalvo10mm,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		26: fbLinearAxis.AxisTargetPos := 40;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 27;
		27: SetCheckpoint(CheckpointID := 124,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		28: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 124 THEN
				iOperatingStep := 29;
			END_IF 
		29: stPlcCom.stPlcComOut.bRingLightGlue := TRUE;
			Trig.bMidStationCam := TRUE;
			iOperatingStep := 25;
		30: IF stCouplerData.bImagingDone THEN
				stPlcCom.stPlcComOut.bRingLightGlue := FALSE;
				Trig.bMidStationCam := FALSE;
				IF stCouplerData.bPartDetectSucceeded THEN
					iOperatingStep := 31;
				ELSIF stCouplerData.bPartDetectFailed THEN
					DisableSetStation(iStationId := iWorkingStation);					// LUO REJECT KÄYTÄNTÖ
					OperatingState := E_OperatingState.FinishedHandling10mm;
					iOperatingStep := 0;
					
				END_IF
			END_IF
		31:	fbLinearAxis.AxisTargetPos := 0;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 32;
		32: MovePose(Pose := PoseSafeInOutGlueSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		33: MoveJoints(Joint_Angle := PoseSafeInOutGlueSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		34: MoveLin(Pose := PoseSafeInOutGlueSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		35: CheckType();
			iOperatingStep := 36;
		36: bBypassState := TRUE;
			 CASE iGluingStep OF
				0: stPlcCom.stPlcComOut.bGlueStopValve := TRUE;
					IF NOT stPlcCom.stPlcComIn.bGlueStopHome THEN
						MoveLin(Pose := PoseGluingSt1, // Pose To gluing
							ExternalStatecontrol := 0,
							ExternalMove_ID := 0,
							Robot:= Meca500.GVL.Meca500, 
							Error=> Error, 
							Sent:= Sent, 
							Buffered:= Buffered);				// LISÄÄ AJASTIN JOKA TARKISTAA ETTÄ VENTTIILI ON AUKI
					END_IF
				1: IF iGluingPoses = 5 THEN
						iGluingStep := 29;
					ELSE
						iGluingStep := 2;
					END_IF
				2:  MoveLin(Pose := PoseGluingSt2,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				3: SetCartLinVel(
						Velocity_Limit := 0.4,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				4: SetCheckpoint(CheckpointID := 102,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				5: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 102 THEN
						//stPlcCom.stPlcComOut.bTriggerGluing1 := TRUE;
						GluingStartTmr2.IN := TRUE;
						iGluingStep := 6;
					END_IF
				6: IF GluingStartTmr2.Q THEN
						GluingTmr2.IN := TRUE;
						GluingStartTmr2.IN := FALSE;
						iGluingStep := 7;
					END_IF
				7:  MoveLin(Pose := PoseGluingSt3,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				8: IF GluingTmr2.Q THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						GluingTmr2.IN := FALSE;
						iGluingStep := 9;
					END_IF
				9: SetCheckpoint(CheckpointID := 104,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				10: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 104 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						IF iGluingPoses = 4 THEN
							iGluingStep := 11;
						ELSIF iGluingPoses = 3 THEN
							iGluingStep := 17;
						END_IF
					END_IF
				11: SetCartLinVel(
						Velocity_Limit := 10*rJogSpeed,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				12: MoveLin(Pose := PoseGluingSt1,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				13: MoveLin(Pose := PoseGluingSt4,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				14: SetCheckpoint(CheckpointID := 105,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				15: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 105 THEN
						//stPlcCom.stPlcComOut.bTriggerGluing1 := TRUE;
						GluingTmr1.IN := TRUE;
						iGluingStep := 16;
					END_IF
				16: IF GluingTmr1.Q THEN
						GluingTmr1.IN := FALSE;
						iGluingStep := 17;
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
					END_IF
				17:  SetCartLinVel(
						Velocity_Limit := 10*rJogSpeed,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				18:  MoveLin(Pose := PoseGluingSt1,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				19: SetCheckpoint(CheckpointID := 106,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				
				20: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 106 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						GluingTmr1.IN := FALSE;
						iGluingStep := 41;
					END_IF
				29:  SetCartLinVel(
						Velocity_Limit := 0.4,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				30: MoveLin(Pose := PoseGluingSt2,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				31: SetCheckpoint(CheckpointID := 102,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				32: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 102 THEN
						//stPlcCom.stPlcComOut.bTriggerGluing1 := TRUE;
						iGluingStep := 33;
					END_IF
				33:  MoveLin(Pose := PoseGluingSt3,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				34: MoveLin(Pose := PoseGluingSt4,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				35: MoveLin(Pose := PoseGluingSt5,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				36: SetCheckpoint(CheckpointID := 109,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				37: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 109 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						iGluingStep := 38;
					END_IF
				38: MoveLin(Pose := PoseGluingSt1,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);	
				39: SetCartLinVel(
						Velocity_Limit := 10*rJogSpeed,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
						
				40: SetCheckpoint(CheckpointID := 106,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				41: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 106 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						stPlcCom.stPlcComOut.bGlueStopValve := FALSE;
						bBypassState := FALSE;
						iOperatingStep := 37;
						iGluingStep := 0;
					END_IF
			END_CASE
			IF Sent AND Buffered AND bBypassState THEN
				iGluingStep := iGluingStep +1;
				Sent := FALSE;
				Buffered := FALSE;
			END_IF

		37:  MoveLin(Pose := PoseSafeInOutGlueSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		38: MoveJoints(Joint_Angle := PoseSafeInOutGlueSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		39: MovePose(Pose := PoseSafeInOutGlueSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		40: MoveJoints(Joint_Angle := PoseAfterGluingSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		41:  fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPlace;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 42;
			stStationPoses.aPoseSmallMotorPlaceSt2[5] := stStationPoses.aPoseSmallMotorPlaceSt2[5] - (stCouplerData.rCouplerAngleDeg);
		42: MovePose(Pose := stStationPoses.aPoseSmallMotorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		43: MoveLin(Pose := stStationPoses.aPoseSmallMotorPlaceSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		44: SetCheckpoint(CheckpointID := 104,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		
		45: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 104 THEN
				EngageHolder();
				StationGripperTmr.IN := TRUE;
				IF StationGripperTmr.Q AND bHolderSensor THEN
					StationGripperTmr.IN := FALSE;
					stStationPoses.aPoseSmallMotorPlaceSt2[5] := 0;
					iOperatingStep := 46;
				END_IF
			END_IF
		46: MoveGripper(mm := 20,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		47: IF EOAT[1] = 1 AND EOAT[0] = 0 THEN
				MoveLin(Pose := stStationPoses.aPoseSmallMotorPlaceSt2,
					ExternalStatecontrol := 0,
					ExternalMove_ID := 0,
					Robot:= Meca500.GVL.Meca500, 
					Error=> Error, 
					Sent:= Sent, 
					Buffered:= Buffered);
			END_IF
		48: MovePose(Pose := stStationPoses.aPoseSmallMotorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		49: SetTrf(
				Pose := PoseTRFMirror,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		50: MoveJoints(Joint_Angle := PoseToMirrorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		51: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosMirrorPickup;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 52;
		52: MoveGripper(mm := 21,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		53: SetGripperForce(
				Force := 5,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		54: MovePose(Pose := stStationPoses.aPoseMirrorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		55: MovePose(Pose := stStationPoses.aPoseMirrorPickupSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		56: MoveGripper(mm := 8,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		57: IF EOAT[0] = 1 THEN
				iOperatingStep := 59;
			END_IF
		59: MovePose(Pose := stStationPoses.aPoseMirrorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		60: SetCheckpoint(CheckpointID := 109,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		61: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 109 THEN
				iOperatingStep := 62;
			END_IF
		62: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPlace;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 63;
		63: MovePose(Pose := stStationPoses.aPoseMirrorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		64: MoveLin(Pose := stStationPoses.aPoseMirrorPlaceSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		65: SetCartLinVel(
				Velocity_Limit := 1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		66: MoveLin(Pose := stStationPoses.aPoseMirrorPlaceSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		67: SetCheckpoint(CheckpointID := 107,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		
		68: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 107 THEN
				EngageSlider();
				stStationPoses.aPoseMirrorPlaceSt1[1] := stStationPoses.aPoseMirrorPlaceSt3[1];
				stStationPoses.aPoseMirrorPlaceSt1[2] := stStationPoses.aPoseMirrorPlaceSt3[2];
				StationGripperTmr.IN := TRUE;
				IF StationGripperTmr.Q AND NOT bSliderSensor THEN
					StationGripperTmr.IN := FALSE;
					iOperatingStep := 69;
				END_IF
			END_IF
		69: MoveGripper(mm := 21,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		70: SetCartLinVel(
				Velocity_Limit := 10*rJogSpeed,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		71: MovePose(Pose := stStationPoses.aPoseMirrorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		72: MoveJoints(Joint_Angle := PoseHome2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		73: OperatingState := E_OperatingState.SetPoses;
// 
		100:  MoveLin(Pose := stStationPoses.aPoseSmallMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		101: MovePose(Pose := PoseHome,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		102: MoveGripper(mm := 24,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		103: SetCheckpoint(CheckpointID := 1000,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		104: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 1000 THEN
				bRobotHomed := TRUE;
				iOperatingStep := 0;
			END_IF
END_CASE
IF Sent AND Buffered AND NOT bBypassState THEN
	iOperatingStep := iOperatingStep +1;
	Sent := FALSE;
	Buffered := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Galvo14mm" Id="{6b89f09a-61d6-4595-b012-fc055ca97ffe}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[bOperatingActive := TRUE;
	eCurrentState := E_CurrentState.GalvoHandling;
	CASE iOperatingStep OF
		0: IF bExecutePlacing THEN
				iOperatingStep := 1;
				bExecutePlacing := FALSE;
			END_IF
		1: MoveGripper(mm := 24,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		2: IF EOAT[5] = 24 THEN	
			SetGripperForce(
				Force := 60,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
			END_IF
		3: SetTrf(
				Pose := PoseTRFMotor,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
			
		4: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosMotorPickup;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 5;
		5: MovePose(Pose := stStationPoses.aPoseLargeMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		6: MoveLin(Pose := stStationPoses.aPoseLargeMotorPickupSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		7: SetCheckpoint(CheckpointID := 120,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		8: IF (stStationPoses.aPoseLargeMotorPickupSt2[1] + 20) < Meca500.GVL.Meca500.Inputs.End_Effector_Pose.SubIndex_001 THEN // If robot is closing on picking up motor but sensor is triggered, pause is flaged
				IF NOT stPlcCom.stPlcComIn.bRobotGripperSensor THEN
					Meca500.GVL.Meca500.Outputs.Motion_Control.Pause := TRUE;
					Meca500.GVL.Meca500.Outputs.Motion_Control.Clear_Move := TRUE;
					IF iWorkingStation <= 5 THEN
						PoseHome := PoseHome1;
					ELSE
						PoseHome := PoseHome2;
					END_IF
					Meca500.GVL.Meca500.Outputs.Motion_Control.Pause := FALSE;
					Meca500.GVL.Meca500.Outputs.Motion_Control.Clear_Move := FALSE;
					iOperatingStep := 9;
				END_IF
			ELSIF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 120 THEN
				IF NOT stPlcCom.stPlcComIn.bRobotGripperSensor THEN
					iOperatingStep := 12;
				ELSE
					IF iWorkingStation <= 5 THEN
						PoseHome := PoseHome1;
					ELSE
						PoseHome := PoseHome2;
					END_IF
					iOperatingStep := 9;
				END_IF
			END_IF
		9:  MoveLin(Pose := stStationPoses.aPoseLargeMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		10:  MoveJoints(Joint_Angle := PoseHome,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);		
		11: DisableSetStation(iStationId := iWorkingStation);
			OperatingState := E_OperatingState.SetPoses;
			iOperatingStep := 0;
		12: MoveGripper(mm := 2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		13: SetCheckpoint(CheckpointID := 101,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		14: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 101 AND EOAT[0] = 1 THEN
				IF EOAT[5] > 6.5 AND EOAT[5] < 7 AND NOT bMotorType THEN		
					iOperatingStep := 17;
				ELSE
					iOperatingStep := 15;
					bThicknessTestFailed := TRUE;
				END_IF
			END_IF
		15: MoveGripper(mm := 19,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		16: iOperatingStep := 9;
		17: MoveLin(Pose := stStationPoses.aPoseLargeMotorPickupSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		18: SetCheckpoint(CheckpointID := 132,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		19: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 132 THEN
				iOperatingStep := 20;
			END_IF
		20: MovePose(Pose := PoseImagingGalvo14mm,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		21: fbLinearAxis.AxisTargetPos := 40;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 22;
		22: SetCheckpoint(CheckpointID := 124,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		23: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 124 THEN
				iOperatingStep := 24;
			END_IF 
		24: stPlcCom.stPlcComOut.bRingLightGlue := TRUE;
			Trig.bMidStationCam := TRUE;
			iOperatingStep := 25;
		25: IF stCouplerData.bImagingDone THEN
				stPlcCom.stPlcComOut.bRingLightGlue := FALSE;
				Trig.bMidStationCam := FALSE;
				IF stCouplerData.bPartDetectSucceeded THEN
					stCouplerData.bImagingDone := FALSE;
					iOperatingStep := 26;
				ELSIF stCouplerData.bPartDetectFailed THEN
					stCouplerData.bImagingDone := FALSE;
					DisableSetStation(iStationId := iWorkingStation);					// LUO REJECT KÄYTÄNTÖ
					OperatingState := E_OperatingState.FinishedHandling14mm;
					iOperatingStep := 0;
				END_IF
			END_IF
		26:	fbLinearAxis.AxisTargetPos := 0;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 27;
		27: MovePose(Pose := PoseSafeInOutGlueSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		28: MoveJoints(Joint_Angle := PoseSafeInOutGlueSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		29: MoveLin(Pose := PoseSafeInOutGlueSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		30: CheckType();
			iOperatingStep := 31;
		31: bBypassState := TRUE;
			 CASE iGluingStep OF
				0: stPlcCom.stPlcComOut.bGlueStopValve := TRUE;
					IF NOT stPlcCom.stPlcComIn.bGlueStopHome THEN
						MoveLin(Pose := PoseGluingSt1, // Pose To gluing
							ExternalStatecontrol := 0,
							ExternalMove_ID := 0,
							Robot:= Meca500.GVL.Meca500, 
							Error=> Error, 
							Sent:= Sent, 
							Buffered:= Buffered);				// LISÄÄ AJASTIN JOKA TARKISTAA ETTÄ VENTTIILI ON AUKI
					END_IF
				1: IF iGluingPoses = 5 THEN
						iGluingStep := 29;
					ELSE
						iGluingStep := 2;
					END_IF
				2:  MoveLin(Pose := PoseGluingSt2,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				3: SetCartLinVel(
						Velocity_Limit := 0.4,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				4: SetCheckpoint(CheckpointID := 102,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				5: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 102 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := TRUE;
						GluingStartTmr2.IN := TRUE;
						iGluingStep := 6;
					END_IF
				6: IF GluingStartTmr2.Q THEN
						GluingTmr2.IN := TRUE;
						GluingStartTmr2.IN := FALSE;
						iGluingStep := 7;
					END_IF
				7:  MoveLin(Pose := PoseGluingSt3,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				8: IF GluingTmr2.Q THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						GluingTmr2.IN := FALSE;
						iGluingStep := 9;
					END_IF
				9: SetCheckpoint(CheckpointID := 104,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				10: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 104 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						IF iGluingPoses = 4 THEN
							iGluingStep := 11;
						ELSIF iGluingPoses = 3 THEN
							iGluingStep := 17;
						END_IF
					END_IF
				11: SetCartLinVel(
						Velocity_Limit := 10*rJogSpeed,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				12: MoveLin(Pose := PoseGluingSt1,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				13: MoveLin(Pose := PoseGluingSt4,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				14: SetCheckpoint(CheckpointID := 105,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				15: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 105 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := TRUE;
						GluingTmr1.IN := TRUE;
						iGluingStep := 16;
					END_IF
				16: IF GluingTmr1.Q THEN
						GluingTmr1.IN := FALSE;
						iGluingStep := 17;
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
					END_IF
				17:  SetCartLinVel(
						Velocity_Limit := 10*rJogSpeed,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				18:  MoveLin(Pose := PoseGluingSt1,  // NOTE!! LINEAR MOVEMENT
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				19: SetCheckpoint(CheckpointID := 106,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				
				20: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 106 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						GluingTmr1.IN := FALSE;
						iGluingStep := 41;
					END_IF
				29:  SetCartLinVel(
						Velocity_Limit := 0.4,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				30: MoveLin(Pose := PoseGluingSt2,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				31: SetCheckpoint(CheckpointID := 102,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				32: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 102 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := TRUE;
						iGluingStep := 33;
					END_IF
				33:  MoveLin(Pose := PoseGluingSt3,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				34: MoveLin(Pose := PoseGluingSt4,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				35: MoveLin(Pose := PoseGluingSt5,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				36: SetCheckpoint(CheckpointID := 109,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				37: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 109 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						iGluingStep := 38;
					END_IF
				38: MoveLin(Pose := PoseGluingSt1,  // NOTE!! LINEAR MOVEMENT Pose where gluing always has to start
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);	
				39: SetCartLinVel(
						Velocity_Limit := 10*rJogSpeed,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
						
				40: SetCheckpoint(CheckpointID := 106,
						ExternalStatecontrol := 0,
						ExternalMove_ID := 0,
						Robot:= Meca500.GVL.Meca500, 
						Error=> Error, 
						Sent:= Sent, 
						Buffered:= Buffered);
				41: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 106 THEN
						stPlcCom.stPlcComOut.bTriggerGluing1 := FALSE;
						stPlcCom.stPlcComOut.bGlueStopValve := FALSE;
						bBypassState := FALSE;
						iOperatingStep := 32;
						iGluingStep := 0;
					END_IF
			END_CASE
			IF Sent AND Buffered AND bBypassState THEN
				iGluingStep := iGluingStep +1;
				Sent := FALSE;
				Buffered := FALSE;
			END_IF

		32:  MoveLin(Pose := PoseSafeInOutGlueSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		33: MoveJoints(Joint_Angle := PoseSafeInOutGlueSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		34: MovePose(Pose := PoseSafeInOutGlueSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		35: MoveJoints(Joint_Angle := PoseAfterGluingSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		36:  fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPlace;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 37;
			stStationPoses.aPoseLargeMotorPlaceSt2[5] := stStationPoses.aPoseLargeMotorPlaceSt2[5] - (stCouplerData.rCouplerAngleDeg);
		37: MovePose(Pose := stStationPoses.aPoseLargeMotorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		38: MoveLin(Pose := stStationPoses.aPoseLargeMotorPlaceSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);	
		39: SetCheckpoint(CheckpointID := 104,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		
		40: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 104 THEN
				EngageHolder();
				StationGripperTmr.IN := TRUE;
				IF StationGripperTmr.Q AND bHolderSensor THEN
					StationGripperTmr.IN := FALSE;
					stStationPoses.aPoseLargeMotorPlaceSt2[5] := 0;
					iOperatingStep := 41;
				END_IF
			END_IF
		41: MoveGripper(mm := 20,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		42: IF EOAT[1] = 1 AND EOAT[0] = 0 THEN
				MoveLin(Pose := stStationPoses.aPoseLargeMotorPlaceSt2,
					ExternalStatecontrol := 0,
					ExternalMove_ID := 0,
					Robot:= Meca500.GVL.Meca500, 
					Error=> Error, 
					Sent:= Sent, 
					Buffered:= Buffered);
// 					iOperatingStep := 43;
			END_IF
		43: MovePose(Pose := stStationPoses.aPoseLargeMotorPlaceSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		44: SetTrf(
				Pose := PoseTRFMirror,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		45: MoveJoints(Joint_Angle := PoseToMirrorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		46: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosMirrorPickup;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 47;
		47: MoveGripper(mm := 21,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		48: SetGripperForce(
				Force := 5,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		49: MovePose(Pose := stStationPoses.aPoseMirrorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		50: MovePose(Pose := stStationPoses.aPoseMirrorPickupSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		51: MoveGripper(mm := 8,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		52: IF EOAT[0] = 1 THEN
				iOperatingStep := 53;
			END_IF
		53: MovePose(Pose := stStationPoses.aPoseMirrorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		54: SetCheckpoint(CheckpointID := 109,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		55: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 109 THEN
				iOperatingStep := 56;
			END_IF
		56: fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPlace;
			OperatingState := E_OperatingState.MoveLinAxis;
			iOperatingStep := 57;
		57: MovePose(Pose := stStationPoses.aPoseMirrorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		58: MoveLin(Pose := stStationPoses.aPoseMirrorPlaceSt2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		59: SetCartLinVel(
				Velocity_Limit := 1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		60: MoveLin(Pose := stStationPoses.aPoseMirrorPlaceSt3,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		61: SetCheckpoint(CheckpointID := 107,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		
		62: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 107 THEN
				EngageSlider();
				stStationPoses.aPoseMirrorPlaceSt1[1] := stStationPoses.aPoseMirrorPlaceSt3[1];
				stStationPoses.aPoseMirrorPlaceSt1[2] := stStationPoses.aPoseMirrorPlaceSt3[2];
				StationGripperTmr.IN := TRUE;
				IF StationGripperTmr.Q AND NOT bSliderSensor THEN
					StationGripperTmr.IN := FALSE;
					iOperatingStep := 63;
				END_IF
			END_IF
		63: MoveGripper(mm := 21,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		64: SetCartLinVel(
				Velocity_Limit := 10*rJogSpeed,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		65: MovePose(Pose := stStationPoses.aPoseMirrorPlaceSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		66: MoveJoints(Joint_Angle := PoseHome2,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		67: OperatingState := E_OperatingState.SetPoses;
			iOperatingStep := 0;
		100:  MoveLin(Pose := stStationPoses.aPoseLargeMotorPickupSt1,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		101: MovePose(Pose := PoseHome,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		102: MoveGripper(mm := 24,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		103: SetCheckpoint(CheckpointID := 1000,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		104: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 1000 THEN
				bRobotHomed := TRUE;
				iOperatingStep := 0;
			END_IF
END_CASE
IF Sent AND Buffered AND NOT bBypassState THEN
	iOperatingStep := iOperatingStep +1;
	Sent := FALSE;
	Buffered := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="Initialize" Id="{b1d364bc-92df-4ed4-bb2e-dbdc6cd8f730}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD Initialize : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
iOperatingStep := 0;
Sent := FALSE;
Buffered := FALSE;
GluingTmr1.IN := FALSE;
GluingTmr2.IN := FALSE;
GluingOffTmr.IN := FALSE;
GluingStartTmr2.IN := FALSE;
StationGripperTmr.IN := FALSE;
eCurrentState := E_CurrentState.Init;
ReleaseTmr.IN := FALSE;
StationGripperTmr.IN :=FALSE;
iMirrorStep := 0;
iFinishedStep := 0;
bDismountingActive := FALSE;]]></ST>
      </Implementation>
    </Method>
    <Action Name="MirrorAdj" Id="{d13ff194-9dff-4689-a5fd-bbb4b7d4855a}" FolderPath="Act\">
      <Implementation>
        <ST><![CDATA[eCurrentState := E_CurrentState.MirrorAdj;
bOperatingActive := TRUE;
CASE iMirrorStep OF
	0: MoveGripper(mm := 20,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	1: IF EOAT[1] = 1 AND EOAT[0] = 0 THEN
			IF iWorkingStation < 5 THEN
				iMirrorStep := 2;
			ELSE
				iMirrorStep := 4;
			END_IF
			
		END_IF
	2: MoveJoints(Joint_Angle := PoseHome2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	3: iMirrorStep := 5;
	4: MoveJoints(Joint_Angle := PoseHome1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	5: SetCheckpoint(CheckpointID := 15,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	6: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 15 THEN
		SetAdjustmentPoses();
			 SetTrf(
				Pose := PoseTRFMirror,
				ExternalStatecontrol := 0,
				ExternalMove_ID := 0,
				Robot:= Meca500.GVL.Meca500, 
				Error=> Error, 
				Sent:= Sent, 
				Buffered:= Buffered);
		END_IF
	7:  fbLinearAxis.AxisTargetPos := stStationPoses.rLinPosPlace;
		OperatingState := E_OperatingState.MoveLinAxis;
		iMirrorStep := 8;
	8:	SetGripperForce(
			Force := 5,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	9: MoveLin(Pose := stStationPoses.aPoseMirrorPlaceSt1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	10: MoveLin(Pose := PoseMirrorAdjustPrev,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	11: MoveGripper(mm := 0,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	12:SetCartLinVel(
			Velocity_Limit := 5,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	13: IF EOAT[0] = 1 THEN
			iMirrorStep := 14;
		END_IF
	14: MoveLin(Pose := PoseMirrorAdjust,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	15: SetCheckpoint(CheckpointID := 16,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	16: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 16 THEN
			iMirrorStep := 17;
		END_IF
	17: MoveGripper(mm := 20,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	18: SetCartLinVel(
			Velocity_Limit := 10*rJogSpeed,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	19: IF EOAT[0] = 0 THEN
			iMirrorStep := 20;
		END_IF
	20: MoveLin(Pose := stStationPoses.aPoseMirrorPlaceSt1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	21: IF iWorkingStation < 5 THEN
			iMirrorStep := 22;
		ELSE
			iMirrorStep := 23;
		END_IF
	22: MoveJoints(Joint_Angle := PoseHome2,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	23: iMirrorStep := 25;
	24: MoveJoints(Joint_Angle := PoseHome1,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	
	25: SetCheckpoint(CheckpointID := 17,
			ExternalStatecontrol := 0,
			ExternalMove_ID := 0,
			Robot:= Meca500.GVL.Meca500, 
			Error=> Error, 
			Sent:= Sent, 
			Buffered:= Buffered);
	26: IF Meca500.GVL.Meca500.Inputs.Motion_Status.ReachedCheckPointId = 17 THEN
			AdjDone();
			iMirrorStep := 0;
			OperatingState := E_OperatingState.SetPoses;
		END_IF
END_CASE
IF Sent AND Buffered THEN
	iMirrorStep := iMirrorStep +1;
	Sent := FALSE;
	Buffered := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="MirrorOffset" Id="{f2318cd9-c83e-421e-8ac9-a9145489dd90}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD MirrorOffset : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	1..5: stStationPoses.aPoseMirrorPlaceSt2[1] := stStationPoses.aPoseMirrorPlaceSt2[1] + stAssemblyData.Station1To5.rMirrorCenterOffsetToWeightCenterY; 
		stStationPoses.aPoseMirrorPlaceSt3[1] := stStationPoses.aPoseMirrorPlaceSt3[1] + stAssemblyData.Station1To5.rMirrorCenterOffsetToWeightCenterY;
	6..10: stStationPoses.aPoseMirrorPlaceSt2[1] := stStationPoses.aPoseMirrorPlaceSt2[1] + stAssemblyData.Station5To10.rMirrorCenterOffsetToWeightCenterY; 
		stStationPoses.aPoseMirrorPlaceSt3[1] := stStationPoses.aPoseMirrorPlaceSt3[1] + stAssemblyData.Station5To10.rMirrorCenterOffsetToWeightCenterY;
END_CASE
]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReleaseHolder" Id="{fced77fd-576b-4edd-aadf-26a3e3edd780}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD ReleaseHolder : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	0: 
	1: stStation.fbSts1.bEngageHolder := FALSE;
		IF stStation.fbSts1.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	2: stStation.fbSts2.bEngageHolder := FALSE;
		IF stStation.fbSts2.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	3: stStation.fbSts3.bEngageHolder := FALSE;
		IF stStation.fbSts3.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	4: stStation.fbSts4.bEngageHolder := FALSE;
		IF stStation.fbSts4.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	5: stStation.fbSts5.bEngageHolder := FALSE;
		IF stStation.fbSts5.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	6: stStation.fbSts6.bEngageHolder := FALSE;
		IF stStation.fbSts6.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	7: stStation.fbSts7.bEngageHolder := FALSE;
		IF stStation.fbSts7.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	8: stStation.fbSts8.bEngageHolder := FALSE;
		IF stStation.fbSts8.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	9: stStation.fbSts9.bEngageHolder := FALSE;
		IF stStation.fbSts9.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	10: stStation.fbSts10.bEngageHolder := FALSE;
		IF stStation.fbSts10.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReleaseSlider" Id="{23f91438-bd72-42e7-b6f5-3d7640c0ab5c}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD ReleaseSlider : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	0: 
	1: stStation.fbSts1.bEngageSlider := FALSE;
		IF stStation.fbSts1.bSliderSensor THEN
			bSliderSensor := FALSE;
		ELSE
