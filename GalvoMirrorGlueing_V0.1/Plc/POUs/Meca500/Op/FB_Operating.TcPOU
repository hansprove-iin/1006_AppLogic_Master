    <Method Name="EngageHolder" Id="{2124621f-833e-4b2e-bd6d-347e3d6cfabe}" FolderPath="Mth\">
      <Declaration><![CDATA[METHOD EngageHolder : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE iWorkingStation OF
	0: 
	1: stStation.fbSts1.bEngageHolder := TRUE;
		IF NOT stStation.fbSts1.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	2: stStation.fbSts2.bEngageHolder := TRUE;
		IF NOT stStation.fbSts2.bHolderSensor THEN
			bHolderSensor := TRUE;
		ELSE
			bHolderSensor := FALSE;
		END_IF
	3: stStation.fbSts3.bEngageHolder := TRUE;
