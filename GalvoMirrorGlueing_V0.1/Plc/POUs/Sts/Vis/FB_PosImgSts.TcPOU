    <Method Name="CouplerDetect" Id="{fc7df348-da54-49d9-a2a6-bc95a43bb5a3}">
      <Declaration><![CDATA[METHOD CouplerDetect : BOOL

VAR
	bCheckOnce 					: BOOL := TRUE;
	hrEdgeT						: HRESULT;
	nIndex						: ULINT;
	
END_VAR


]]></Declaration>
      <Implementation>
        <ST><![CDATA[hrEdgeT := 0;

aStartPointCoupler1[0] := 1000;
aStartPointCoupler1[1] := 1000;
aEndPointCoupler1[0] := 550;
aEndPointCoupler1[1] := 1000;

		
hrEdgeT := F_VN_LocateEdge(
	ipSrcImage:= ImageRaw, 
	ipEdgePoints:= ipEdgePointsCoupler1, 
	aStartPoint:= aStartPointCoupler1, 
	aEndPoint:= aEndPointCoupler1, 
	eEdgeDirection:= ETcVnEdgeDirection.TCVN_ED_Light_TO_Dark, 
	fMinStrength:= 45, 
	nSearchLines:= 5, 
	hrPrev:= hr, 
	fAvgStrength=> );
	
hrEdgeT := F_VN_GetAt_TcVnVector2_REAL(ipContainer:= ipEdgePointsCoupler1, aElement:= aElementCoupler1, nIndex:= 0, hrPrev:= hrEdgeT);
	
aStartPointCoupler2[0] := aElementCoupler1[0]-40;
aStartPointCoupler2[1] := 600;
aEndPointCoupler2[0] := aElementCoupler1[0]-40;
aEndPointCoupler2[1] := 1000;	

aStartPointCoupler3[0] := aElementCoupler1[0]-40;
aStartPointCoupler3[1] := 1400;
aEndPointCoupler3[0] := aElementCoupler1[0]-40;
aEndPointCoupler3[1] := 1000;	

hrEdgeT := F_VN_LocateEdge(
	ipSrcImage:= ImageRaw, 
	ipEdgePoints:= ipEdgePointsCoupler2, 
	aStartPoint:= aStartPointCoupler2, 
	aEndPoint:= aEndPointCoupler2, 
	eEdgeDirection:= ETcVnEdgeDirection.TCVN_ED_Light_TO_Dark, 
	fMinStrength:= 45, 
	nSearchLines:= 4, 
	hrPrev:= hr, 
	fAvgStrength=> );
hrEdgeT := F_VN_LocateEdge(
	ipSrcImage:= ImageRaw, 
	ipEdgePoints:= ipEdgePointsCoupler3, 
	aStartPoint:= aStartPointCoupler3, 
	aEndPoint:= aEndPointCoupler3, 
	eEdgeDirection:= ETcVnEdgeDirection.TCVN_ED_Light_TO_Dark, 
	fMinStrength:= 45, 
	nSearchLines:= 4, 
	hrPrev:= hr, 
	fAvgStrength=> );
IF SUCCEEDED(hrEdgeT) THEN
	hrEdgeT := F_VN_DrawPoints(
		ipPoints:= ipEdgePointsCoupler1, 
		ipDestImage:= ipImageProsessed, 
		eShape:= ETcVnDrawShape.TCVN_DS_X, 
		aColor:= Color.Lime, 
		hrPrev:= hr);

	hrEdgeT := F_VN_DrawPoints(
		ipPoints:= ipEdgePointsCoupler2, 
		ipDestImage:= ipImageProsessed, 
		eShape:= ETcVnDrawShape.TCVN_DS_X, 
		aColor:= Color.Lime, 
		hrPrev:= hr);
		
	hrEdgeT := F_VN_DrawPoints(
		ipPoints:= ipEdgePointsCoupler3, 
		ipDestImage:= ipImageProsessed, 
		eShape:= ETcVnDrawShape.TCVN_DS_X, 
		aColor:= Color.Lime, 
		hrPrev:= hr);
	FOR nIndex := 0 TO 4 DO
		hrEdgeT := F_VN_GetAt_TcVnVector2_REAL(ipContainer:= ipEdgePointsCoupler2, aElement:= aElementCoupler2[nIndex], nIndex:= nIndex, hrPrev:= hrEdgeT);
		hrEdgeT := F_VN_GetAt_TcVnVector2_REAL(ipContainer:= ipEdgePointsCoupler3, aElement:= aElementCoupler3[nIndex], nIndex:= nIndex, hrPrev:= hrEdgeT);
	END_FOR
	aCouplerAverage2[0] := REAL_TO_ULINT((aElementCoupler2[0][0] + aElementCoupler2[1][0] + aElementCoupler2[2][0] + aElementCoupler2[3][0]+ aElementCoupler2[4][0] )/ 5);
	aCouplerAverage2[1] := REAL_TO_ULINT((aElementCoupler2[0][1] + aElementCoupler2[1][1] + aElementCoupler2[2][1] + aElementCoupler2[3][1]+ aElementCoupler2[4][1] )/ 5);
	aCouplerAverage3[0] := REAL_TO_ULINT((aElementCoupler3[0][0] + aElementCoupler3[1][0] + aElementCoupler3[2][0] + aElementCoupler3[3][0]+ aElementCoupler3[4][0] )/ 5);
	aCouplerAverage3[1] := REAL_TO_ULINT((aElementCoupler3[0][1] + aElementCoupler3[1][1] + aElementCoupler3[2][1] + aElementCoupler3[3][1]+ aElementCoupler3[4][1] )/ 5);
	aCouplerCenterpoint[0] := (aCouplerAverage2[0] + aCouplerAverage3[0])/2;
	aCouplerCenterpoint[1] := (aCouplerAverage2[1] + aCouplerAverage3[1])/2;
	hr := F_VN_CopyIntoDisplayableImage (ipImageProsessed, ipImageProsessedDisp, hr);
	
	
ELSE
	IF bCheckOnce THEN
		ADSLOGSTR(msgCtrlMask := ADSLOG_MSGTYPE_ERROR, msgFmtStr := 'Error1', strArg:= ' ');
		bCheckOnce := FALSE;
	END_IF
END_IF
	

]]></ST>
      </Implementation>
    </Method>
    <Method Name="MirrorDetect" Id="{95c7a0cd-7528-4c61-b73c-84f071c64dbc}">
      <Declaration><![CDATA[METHOD MirrorDetect : BOOL
VAR_INPUT
END_VAR
VAR
	aPoint1 : TcVnPoint2_REAL := [0,0];
	aPoint2 : TcVnPoint2_REAL := [0,1];	
	
  	aCameraMatrix           : TcVnMatrix3x3_LREAL;
    aDistortionCoefficients : TcVnArray8_LREAL;
    aRotationMatrix         : TcVnMatrix3x3_LREAL;
    aTranslationVector      : TcVnVector3_LREAL;
	

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbCamera.GetCameraMatrix(aCameraMatrix := aCameraMatrix);
fbCamera.GetDistortionCoefficients(aDistortionCoefficients := aDistortionCoefficients);
fbCamera.GetRotationMatrix(aRotationMatrix := aRotationMatrix);
fbCamera.GetTranslationVector(aTranslationVector := aTranslationVector);

hr := F_VN_ImagePointsWorldDistance( 
	aImagePoint1 := aPoint1,
	aImagePoint2 := aPoint2,
	fWorldDistance := rWorldDistance,
	aCameraMatrix := aCameraMatrix,
	aDistortionCoefficients := aDistortionCoefficients,
	aRotationMatrix := aRotationMatrix,
	aTranslationVector := aTranslationVector,
	fZ := 0,
	hrPrev := hr);
	

CASE iStationId OF
 	1..5:
	aMirrorEdgeCalc[1] := stAssemblyType.Station1To5.rMirrorCenterOffsetToWeightCenterY/rWorldDistance; // calculates the distance in px of the mirror centerpoint to weight centerpoint. Is used to determine currect positioning of the mirror 
	
	// Detection from center to upper edge
	aStartPointMirror1[0] := aCouplerCenterpoint[0] - ((stAssemblyType.Station1To5.rCouplerGroveDepth)/rWorldDistance) + (stAssemblyType.Station1To5.rMirrorGripPointOffsetToEdgeX/rWorldDistance) ;
	aStartPointMirror1[1] := aCouplerCenterpoint[1]; // Coupler centerpoint based Y Startpoint
	aEndPointMirror1[0] := aStartPointMirror1[0];
	aEndPointMirror1[1] := aCouplerCenterpoint[1] - (((stAssemblyType.Station1To5.rMirrorDimensions[1]/2) - stAssemblyType.Station1To5.rMirrorCenterOffsetToWeightCenterY)/rWorldDistance)-100; // endpoint based on coupler centerpoint - mirror weight centerpoint to edge width + some extra
	// detection from center to lower edge
	aStartPointMirror2[0] := aCouplerCenterpoint[0] - ((stAssemblyType.Station1To5.rCouplerGroveDepth)/rWorldDistance) + (stAssemblyType.Station1To5.rMirrorGripPointOffsetToEdgeX/rWorldDistance);
	aStartPointMirror2[1] := aCouplerCenterpoint[1];
	aEndPointMirror2[0] := aStartPointMirror2[0];
	aEndPointMirror2[1] := aCouplerCenterpoint[1] + (((stAssemblyType.Station1To5.rMirrorDimensions[1]/2) - stAssemblyType.Station1To5.rMirrorCenterOffsetToWeightCenterY)/rWorldDistance)+100;
	
	6..10:
	aStartPointMirror1[0] := 0;
	aStartPointMirror1[1] := 0;
	aEndPointMirror1[0] := 0;
	aEndPointMirror1[1] := 0;
			
	aStartPointMirror2[0] := 0;
	aStartPointMirror2[1] := 0;
	aEndPointMirror2[0] := 0;
	aEndPointMirror2[1] := 0;
END_CASE

hr := F_VN_LocateEdge(
	ipSrcImage:= ImageRaw, 
	ipEdgePoints:= ipEdgePointsMirror1, 
	aStartPoint:= aStartPointMirror1, 
	aEndPoint:= aEndPointMirror1, 
	eEdgeDirection:= ETcVnEdgeDirection.TCVN_ED_DARK_TO_LIGHT, 
	fMinStrength:= 45, 
	nSearchLines:= 1, 
	hrPrev:= hr, 
	fAvgStrength=> );
hr := F_VN_LocateEdge(
	ipSrcImage:= ImageRaw, 
	ipEdgePoints:= ipEdgePointsMirror2, 
	aStartPoint:= aStartPointMirror2, 
	aEndPoint:= aEndPointMirror2, 
	eEdgeDirection:= ETcVnEdgeDirection.TCVN_ED_DARK_TO_LIGHT, 
	fMinStrength:= 45, 
	nSearchLines:= 1, 
	hrPrev:= hr, 
	fAvgStrength=> );
	IF SUCCEEDED(hr) THEN
		hr := F_VN_GetAt_TcVnVector2_REAL(ipContainer:= ipEdgePointsMirror1, aElement:= aElementMirror1, nIndex:= 0, hrPrev:= hr);
		hr := F_VN_GetAt_TcVnVector2_REAL(ipContainer:= ipEdgePointsMirror2, aElement:= aElementMirror2, nIndex:= 0, hrPrev:= hr);
		hr := F_VN_DrawPoints(
			ipPoints:= ipEdgePointsMirror1, 
			ipDestImage:= ipImageProsessed, 
			eShape:= ETcVnDrawShape.TCVN_DS_X, 
			aColor:= Color.Lime, 
			hrPrev:= hr);
		hr := F_VN_DrawPoints(
			ipPoints:= ipEdgePointsMirror2, 
			ipDestImage:= ipImageProsessed, 
			eShape:= ETcVnDrawShape.TCVN_DS_X, 
			aColor:= Color.Lime, 
			hrPrev:= hr);
		stPosData.rMirrorOffsetToCalPoints[1] := (( aCouplerCenterpoint[1]) - ((aElementMirror1[1] + aElementMirror2[1])/2) - aMirrorEdgeCalc[1])*rWorldDistance;
		hr := F_VN_CopyIntoDisplayableImage (ipImageProsessed, ipImageProsessedDisp, hr);
	END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TrigImage" Id="{593084b8-639d-4f92-864e-9807bab846e2}">
      <Declaration><![CDATA[METHOD TrigImage : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbCamera.TriggerImage();
bInitTrig := TRUE;
TrigCheckTmr.IN := TRUE;]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>