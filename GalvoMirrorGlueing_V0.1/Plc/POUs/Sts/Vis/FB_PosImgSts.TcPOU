<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PosImgSts" Id="{610d78e7-c428-4260-8f99-31feeba05a81}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_PosImgSts
VAR_INPUT
	bTrigLightTestImage	: BOOL;
	bTrigLaserTestImage	: BOOL;
	bTrigCouplerImage		: BOOL;
	stPosData	: REFERENCE TO ST_Vis_Mirror;
	stAssemblyType : REFERENCE TO ST_Recipes;
	nX		: UDINT;
	nY		: UDINT;
	iStationId	: INT;
	stModuleHmi	: REFERENCE TO ST_ModuleHmi;
END_VAR
VAR_OUTPUT
	bImageReceived : BOOL;
	bPartDetectFailed : BOOL;
	iErrorId			: INT;
	bDone : BOOL;
END_VAR
VAR
	hr									: HRESULT;
	eVisionState						: ETcVnCameraState;
	fbCamera          					: FB_VN_GevCameraControl;
	ImageRawDisp						: ITcVnDisplayableImage;
	nNewImageCounter 					: UINT;
	ImageRaw							: Tc3_Vision.ITcVnImage;
	ipImageProsessed					: Tc3_Vision.ITcVnImage;
	ipImageProsessedDisp				: Tc3_Vision.ITcVnDisplayableImage;
	ipImageTest							: ITcVnImage;
	ipImageTestDisp						: ITcVnDisplayableImage;

	aStartPointCoupler1 				: TcVnPoint2_REAL;
	aEndPointCoupler1					: TcVnPoint2_REAL;
	
	ipEdgePointsCoupler1   				: ITcVnContainer;
	ipEdgePointsCoupler2				: ITcVnContainer;
	ipEdgePointsCoupler3				: ITcVnContainer;
	
	aStartPointCoupler2 				: TcVnPoint2_REAL;
	aEndPointCoupler2					: TcVnPoint2_REAL;
	aStartPointCoupler3 				: TcVnPoint2_REAL;
	aEndPointCoupler3					: TcVnPoint2_REAL;
	
	aStartPointMirror1 					: TcVnPoint2_REAL;
	aEndPointMirror1					: TcVnPoint2_REAL;
	aStartPointMirror2 					: TcVnPoint2_REAL;
	aEndPointMirror2					: TcVnPoint2_REAL;
	ipEdgePointsMirror1   				: ITcVnContainer;
	ipEdgePointsMirror2   				: ITcVnContainer;
	aElementMirror1						: TcVnPoint2_REAL;
	aElementMirror2						: TcVnPoint2_REAL;
	
	aMirrorEdgeCalc			: TcVnPoint2_REAL;
	aMirrorEdgeReal			: TcVnPoint2_REAL;
	

	
	rThreshold			: LREAL := 45;
	rMaxvalue			: LREAL := 255;

	stDetectionAreaLed						: TcVnRectangle_UDINT;
	stDetectionAreaLaser					: TcVnRectangle_UDINT;
	aAverageLed  							: TcVnVector4_LREAL;
	aAverageLaser  							: TcVnVector4_LREAL;
	aElementCoupler1 						: TcVnPoint2_REAL; 
	aElementCoupler2						: ARRAY [0..5] OF TcVnPoint2_REAL;
	aElementCoupler3						: ARRAY [0..5] OF TcVnPoint2_REAL;
	aCouplerAverage2						: TcVnPoint2_REAL;
	aCouplerAverage3						: TcVnPoint2_REAL;
	aCouplerCenterpoint						: TcVnPoint2_REAL;
	rWorldDistance							: LREAL;
	fbEventlogger							: FB_EventLogger;
	bInitTrig 								: BOOL;
	TrigCheckTmr							: TON;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[fbEventlogger(stModuleHmi:=stModuleHmi);
eVisionState := fbCamera.GetState();

stDetectionAreaLed.nHeight := 200;
stDetectionAreaLed.nWidth := 200;
stDetectionAreaLed.nX := 1800;
stDetectionAreaLed.nY := 900;

stDetectionAreaLaser.nHeight := 20;
stDetectionAreaLaser.nWidth := 20;
stDetectionAreaLaser.nX := nX;
stDetectionAreaLaser.nY := nY;

bDone := FALSE;
bImageReceived := FALSE;
hr := 0;
TrigCheckTmr(PT := T#1S);


IF eVisionState = TCVN_CS_ERROR THEN
	hr := fbCamera.Reset();
ELSIF eVisionState = TCVN_CS_TRIGGERING THEN
	hr := fbCamera.TriggerImage();
ELSIF eVisionState < TCVN_CS_ACQUIRING THEN
    hr := fbCamera.StartAcquisition();
ELSIF eVisionState = TCVN_CS_ACQUIRING THEN
	hr := fbCamera.GetCurrentImageUndistorted(ImageRaw); 
	IF SUCCEEDED(hr) AND ImageRaw <> 0 THEN
		bPartDetectFailed := FALSE;
		bImageReceived := TRUE;
		nNewImageCounter := nNewImageCounter +1;
// 		hr := F_VN_CopyImage(ImageRaw, ipImageProsessed, hr);
// 		hr := F_VN_CopyIntoDisplayableImage (ImageRaw, ImageRawDisp, hr);
		bInitTrig := FALSE;
		TrigCheckTmr.IN := FALSE;
		hr := F_VN_ConvertColorSpace(ipSrcImage:= ImageRaw , ipDestImage:= ipImageProsessed ,
			eTransform:= ETcVnColorSpaceTransform.TCVN_CST_GRAY_TO_RGB, hrPrev:= hr);
		IF bTrigLightTestImage THEN
			hr := F_VN_CopyImage(ImageRaw, ipImageTest, hrPrev := hr);
			hr := F_VN_SetRoi_TcVnRectangle_UDINT(stRoi:= stDetectionAreaLed, ipDestImage:= ipImageTest, hrPrev:= hr);
			hr := F_VN_ImageAverage(ipSrcImage:= ipImageTest, aAverage:= aAverageLed, hrPrev:= hr);
			hr := F_VN_ResetRoi(ipImage:= ipImageTest, hrPrev:= hr);
			hr:= F_VN_ConvertColorSpace(ipSrcImage:= ipImageTest , ipDestImage:= ipImageTest ,
				eTransform:= ETcVnColorSpaceTransform.TCVN_CST_GRAY_TO_RGB, hrPrev:= hr);
			hr := F_VN_DrawRectangle_TcVnRectangle_UDINT(
				stRectangle:= stDetectionAreaLed,
				ipDestImage:= ipImageTest,
				aColor:= Color.Green,
				nThickness:= 1,
				hrPrev:= hr);
			hr := F_VN_CopyIntoDisplayableImage (ipImageTest, ipImageTestDisp, hr);	
			IF aAverageLed[0] > 230 THEN
				stPosData.bLightTestOk := TRUE;
				stPosData.bDetectionFailed := FALSE;
			ELSE
				stPosData.bLightTestOk := FALSE;
				stPosData.bDetectionFailed := TRUE;
			END_IF
			bTrigLightTestImage := FALSE;
		ELSIF bTrigLaserTestImage THEN
			hr := F_VN_CopyImage(ImageRaw, ipImageTest, hrPrev := hr);
			hr := F_VN_SetRoi_TcVnRectangle_UDINT(stRoi:= stDetectionAreaLaser, ipDestImage:= ipImageTest, hrPrev:= hr);
			hr := F_VN_ImageAverage(ipSrcImage:= ipImageTest, aAverage:= aAverageLaser, hrPrev:= hr);
			hr := F_VN_ResetRoi(ipImage:= ipImageTest, hrPrev:= hr);
			hr:= F_VN_ConvertColorSpace(ipSrcImage:= ipImageTest , ipDestImage:= ipImageTest ,
				eTransform:= ETcVnColorSpaceTransform.TCVN_CST_GRAY_TO_RGB, hrPrev:= hr);
			hr := F_VN_DrawRectangle_TcVnRectangle_UDINT(
				stRectangle:= stDetectionAreaLaser,
				ipDestImage:= ipImageTest,
				aColor:= Color.Green,
				nThickness:= 1,
				hrPrev:= hr);
			hr := F_VN_CopyIntoDisplayableImage (ipImageTest, ipImageTestDisp, hr);	
			IF aAverageLaser[0] > 230 THEN
				stPosData.bLaserTestOk := TRUE;
				stPosData.bDetectionFailed := FALSE;
			ELSE
				stPosData.bLaserTestOk := FALSE;
				stPosData.bDetectionFailed := TRUE;
			END_IF
			bTrigLaserTestImage := FALSE;
		ELSIF bTrigCouplerImage THEN	
			CouplerDetect();			
			bTrigCouplerImage := FALSE;
			stPosData.bImagingDone := TRUE;		
		ELSE
 			MirrorDetect();
			stPosData.bImagingDone := TRUE;	
		END_IF
	ELSIF bInitTrig AND TrigCheckTmr.Q THEN
		iErrorId := 304;
		fbEventlogger.bRaiseAlarm[11]:=TRUE;
		fbEventlogger.sErrorCode:= CONCAT(CONCAT('3', INT_TO_STRING(iStationId)), '4');
		bInitTrig := FALSE;
		TrigCheckTmr.IN := FALSE;
	END_IF
END_IF
			]]></ST>
    </Implementation>
    <Method Name="CheckType" Id="{fadba1b2-c425-435e-9084-8f9efdd12b33}">
