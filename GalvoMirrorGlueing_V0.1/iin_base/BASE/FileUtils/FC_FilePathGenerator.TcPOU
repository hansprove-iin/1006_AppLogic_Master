  <POU Name="FC_FilePathGenerator" Id="{063c12d0-8836-4cce-adee-4e73ee1cd8a6}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION FC_FilePathGenerator : T_MaxString
