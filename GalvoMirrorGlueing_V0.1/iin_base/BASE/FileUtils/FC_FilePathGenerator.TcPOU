	iPath:			T_MaxString;
	iFile:			T_MaxString;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[FC_FilePathGenerator := FC_3strConcat(iStr1 := iPath, iStr2 := IING.STRING_BACKSLASH, iStr3 := iFile);
]]></ST>
    </Implementation>
    <LineIds Name="FC_FilePathGenerator">
      <LineId Id="2" Count="1" />
    </LineIds>
