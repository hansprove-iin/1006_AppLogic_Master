  <DUT Name="ST_CONTROL_SIGNALS_V2" Id="{86de0c16-9814-47c8-92b1-2be13cbecff9}">
    <Declaration><![CDATA[TYPE ST_CONTROL_SIGNALS_V2 :	// Control signals (auto/manual/service/...) for use in programs 
