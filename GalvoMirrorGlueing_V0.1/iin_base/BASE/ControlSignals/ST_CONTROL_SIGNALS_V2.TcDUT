	in:				 	ST_CONTROL_SIGNALS_IN;
	out:				ST_CONTROL_SIGNALS_OUT;
	
	settings:			REFERENCE TO ST_CONTROL_SIGNALS_SETTINGS;
	staticSettings:		REFERENCE TO ST_CONTROL_SIGNALS_STATIC_SETTINGS;
END_STRUCT
END_TYPE
]]></Declaration>
  </DUT>
