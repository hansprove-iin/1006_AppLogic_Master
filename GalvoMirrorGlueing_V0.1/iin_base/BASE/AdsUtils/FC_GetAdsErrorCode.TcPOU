	1816:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_NOTINIT;
	
	1817:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_TIMEOUT;
	
	1818:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_NOINTERFACE;
	
	1819:
