	1798:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_INVALIDDATA;

	1799:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_NOTREADY;

	1800:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_BUSY;

	1801:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_INVALIDCONTEXT;

	1802:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_NOMEMORY;
	
	1803:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_INVALIDPARM;
	
	1804:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_NOTFOUND;		// Eg. Opening a file which does not exist
	
	1805:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_SYNTAX;
	
	1806:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_INCOMPATIBLE;
	
	1807:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_EXISTS;
	
	1808:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_SYMBOLNOTFOUND;
	
	1809:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_SYMBOLVERSIONINVAL;
	
	1810:
