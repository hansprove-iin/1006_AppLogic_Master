<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FC_GetAdsErrorCode" Id="{90a8de5b-74d3-4c1a-aa19-f183fd2a3612}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION FC_GetAdsErrorCode : E_ADS_ERRORS		// Converts an error number into an ADS enum error code
VAR_INPUT
	iErrorCode:	UDINT;		// The error code as a number
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[CASE iErrorCode OF
	0:
		FC_GetAdsErrorCode := E_ADS_ERRORS.NO_ERROR;

	6:
		FC_GetAdsErrorCode := E_ADS_ERRORS.TARGET_PORT_NOT_FOUND;
		
	7:
		FC_GetAdsErrorCode := E_ADS_ERRORS.TARGET_MACHINE_NOT_FOUND;
	
	1792:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_ERROR;
	
	1793:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_SRVNOTSUPP; 
	
	1794:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_INVALIDGRP; 
	
	1795:
		FC_GetAdsErrorCode := E_ADS_ERRORS.ADSERR_DEVICE_INVALIDOFFSET;
	
	1796:
